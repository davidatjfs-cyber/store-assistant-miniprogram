/* 数据看板 - 液态玻璃 (高亮银色) */
page { background: #0a0a0a; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 32rpx;
}

.sub {
  display: block; font-size: 28rpx; font-weight: 600; color: #ffffff; margin-bottom: 8rpx;
  text-shadow: 0 0 10rpx rgba(255,255,255,0.4);
}

.date { display: block; font-size: 24rpx; color: #B0B0B0; margin-bottom: 24rpx; }
.state { text-align: center; padding: 100rpx 24rpx; color: #C0C0C0; font-size: 28rpx; }
.state--small { padding: 24rpx; font-size: 26rpx; }

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx; padding: 32rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
}

.metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 24rpx; }

.metric {
  text-align: center; padding: 24rpx 16rpx; background: rgba(255,255,255,0.05);
  border-radius: 20rpx; border: 1rpx solid rgba(255,255,255,0.08);
}
.metric-wide { grid-column: 1 / -1; }

.metric-icon {
  display: block; width: 56rpx; height: 56rpx; line-height: 56rpx; margin: 0 auto 12rpx;
  border-radius: 16rpx; background: linear-gradient(135deg, rgba(255,106,0,0.6), rgba(255,133,51,0.4));
  color: #fff; font-size: 28rpx; font-weight: 700;
}

.metric-val {
  display: block; font-size: 44rpx; font-weight: 700; color: #ffffff;
  text-shadow: 0 0 12rpx rgba(255,255,255,0.5);
}
.metric-money { color: #ff9a5c; text-shadow: 0 0 12rpx rgba(255,106,0,0.5); }
.metric-label { display: block; margin-top: 8rpx; font-size: 24rpx; color: #B0B0B0; }

.section-title { font-size: 28rpx; font-weight: 600; color: #ffffff; margin-bottom: 20rpx; display: block; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }

.roi-list { display: flex; flex-direction: column; gap: 12rpx; }

.roi-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 24rpx; background: rgba(255,255,255,0.05);
  border-radius: 16rpx; border: 1rpx solid rgba(255,255,255,0.08);
}

.roi-name { flex: 1; font-size: 28rpx; color: #D0D0D0; padding-right: 16rpx; }
.roi-num { font-size: 30rpx; font-weight: 600; color: #ff9a5c; text-shadow: 0 0 8rpx rgba(255,106,0,0.4); }
