<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>
  <view class="hero">
    <view class="hero-shell">
      <view class="hero-copy">
        <text class="hero-kicker">ADMIN DASHBOARD</text>
        <text class="hero-title">经营概览</text>
        <text class="sub" wx:if="{{subtitle}}">{{subtitle}}</text>
        <text class="date" wx:if="{{date}}">统计日 {{date}}</text>
      </view>
      <view class="hero-lens"></view>
    </view>
  </view>

  <view class="dashboard-controls" wx:if="{{isAdmin || !isAllStores}}">
    <view class="control-row">
      <button class="toggle-btn {{isAllStores ? '' : 'toggle-btn--secondary'}}" bindtap="onToggleView">{{isAllStores ? '按门店查看' : '查看全部'}}</button>
      <picker wx:if="{{!isAllStores}}" mode="selector" range="{{stores}}" range-key="name" value="{{storeIndex}}" bindchange="onStoreChange">
        <view class="store-picker">
          <text class="store-picker-text">{{stores[storeIndex].name}} ▼</text>
        </view>
      </picker>
    </view>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <block wx:else>
    <view class="glass-card metrics-grid">
      <view class="metric">
        <text class="metric-kicker">ISSUED</text>
        <text class="metric-val">{{issuedToday}}</text>
        <text class="metric-label">今日发券</text>
      </view>
      <view class="metric">
        <text class="metric-kicker">USED</text>
        <text class="metric-val">{{usedToday}}</text>
        <text class="metric-label">今日核销</text>
      </view>
      <view class="metric metric-wide">
        <text class="metric-kicker">REVENUE</text>
        <text class="metric-val metric-money">¥{{revenueYuan}}</text>
        <text class="metric-label">今日收入</text>
      </view>
    </view>

    <view class="glass-card">
      <text class="section-title">各规则 ROI（今日）</text>
      <view wx:if="{{!rules.length}}" class="state state--small">暂无规则数据</view>
      <view wx:else class="roi-list">
        <view class="roi-item" wx:for="{{rules}}" wx:key="rule_id">
          <text class="roi-name">{{item.name}}</text>
          <text class="roi-num">{{item.roiText}}</text>
        </view>
      </view>
    </view>
  </block>
</view>