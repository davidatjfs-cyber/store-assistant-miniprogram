<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>
  <view class="hero">
    <view class="hero-shell">
      <view class="hero-copy">
        <text class="hero-kicker">TABLE QR CODES</text>
        <text class="hero-title">{{storeName}}</text>
        <text class="hint">桌位点餐码 · 共 {{totalTables}} 桌</text>
      </view>
      <view class="hero-lens"></view>
    </view>
  </view>

  <view class="store-bar">
    <picker mode="selector" range="{{stores}}" range-key="name" value="{{storeIndex}}" bindchange="onStoreChange">
      <view class="store-picker"><text class="store-picker-text">{{stores[storeIndex].name}} ▼</text></view>
    </picker>
  </view>

  <view class="btn-bar">
    <button class="btn-add" bindtap="onGenerateAll" loading="{{generating}}">{{generating ? '生成中…' : (generatedCount ? '重新生成全部' : '生成全部桌码')}}</button>
    <text class="btn-hint" wx:if="{{generatedCount > 0}}">已生成 {{generatedCount}} / {{totalTables}} 桌</text>
    <button wx:if="{{generatedCount > 0}}" class="btn-save" bindtap="onSaveAllImages" loading="{{saving}}">{{saving ? '保存中 ' + saveProgress : '保存全部图片到相册（含桌号）'}}</button>
  </view>

  <scroll-view scroll-y class="list">
    <view class="zone-card" wx:for="{{zones}}" wx:for-item="zone" wx:key="name">
      <view class="zone-header">
        <text class="zone-title">{{zone.name}}</text>
        <text class="zone-count">{{zone.tables.length}} 桌</text>
      </view>
      <view class="qr-grid">
        <view class="qr-cell" wx:for="{{zone.tables}}" wx:for-item="tbl" wx:key="id">
          <image wx:if="{{tbl.qrBase64}}" class="qr-img" src="data:image/png;base64,{{tbl.qrBase64}}" mode="aspectFit" bindtap="previewQr" data-base64="{{tbl.qrBase64}}" />
          <view wx:else class="qr-placeholder"><text class="qr-placeholder-text">{{tbl.id}}</text></view>
          <text class="qr-label">{{tbl.id}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="tip-bar" wx:if="{{generatedCount > 0}}">
    <text class="tip-text">点击二维码可放大预览 · 点击下方「保存全部图片」逐张保存到相册，每张图片自带桌号</text>
  </view>

  <!-- 隐藏 Canvas：用于合成二维码+桌号 -->
  <canvas type="2d" id="saveCanvas" style="width:500px;height:620px;position:fixed;left:-9999px;top:0;pointer-events:none;"></canvas>
</view>