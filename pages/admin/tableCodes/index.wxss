page { background: #0d0d0d; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 0%, rgba(201,169,110,0.08), transparent 32%),
    radial-gradient(circle at 84% 10%, rgba(160,120,60,0.06), transparent 36%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; }
.ambient-a { width: 300rpx; height: 300rpx; right: -80rpx; top: 40rpx; background: radial-gradient(circle, rgba(255,255,255,0.10), rgba(201,169,110,0.08) 34%, transparent 72%); filter: blur(16rpx); }
.ambient-b { width: 360rpx; height: 360rpx; left: -140rpx; bottom: 100rpx; background: radial-gradient(circle, rgba(120,160,255,0.06), transparent 74%); filter: blur(26rpx); }

.hero { padding: 20rpx 4rpx 28rpx; }
.hero-shell {
  display: flex; align-items: center; justify-content: space-between; gap: 22rpx;
  padding: 24rpx; border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.07), rgba(201,169,110,0.04) 40%, rgba(120,160,255,0.04));
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display: block; margin-bottom: 14rpx; font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 800; }
.hero-title { font-size: 48rpx; font-weight: 900; color: #eef2ff; text-shadow: 0 8rpx 30rpx rgba(157,187,255,0.10); }
.hint { font-size: 24rpx; color: #99a8c8; margin-top: 8rpx; }
.hero-lens {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.28), rgba(201,169,110,0.18) 48%, transparent 100%);
  border: 1rpx solid rgba(255,255,255,0.14);
  flex-shrink: 0;
}

.btn-bar { margin-bottom: 24rpx; text-align: center; }
.btn-add {
  width: 100%;
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important; border: none !important;
  border-radius: 999rpx !important;
  padding: 12rpx 32rpx !important; font-size: 28rpx !important; font-weight: 800 !important;
}
.btn-add::after { border: none; }
.btn-save {
  margin-top: 12rpx; width: 100%;
  background: rgba(201,169,110,0.10) !important; color: #d4b87a !important;
  border: 1rpx solid rgba(201,169,110,0.28) !important; border-radius: 999rpx !important;
  padding: 10rpx 28rpx !important; font-size: 26rpx !important; font-weight: 700 !important;
}
.btn-save::after { border: none; }
.btn-hint { display: block; margin-top: 12rpx; font-size: 24rpx; color: #99a8c8; }

.store-bar { margin-bottom: 16rpx; text-align: center; }
.store-picker { display: inline-block; padding: 14rpx 28rpx; background: linear-gradient(135deg, rgba(255,255,255,0.09), rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%); border-radius: 999rpx; border: 1rpx solid rgba(201,169,110,0.24); }
.store-picker-text { font-size: 26rpx; color: #d4b87a; font-weight: 700; }
.btn-row { display: flex; gap: 16rpx; margin-top: 16rpx; }
.btn-secondary,
.btn-ghost {
  flex: 1;
  border-radius: 999rpx !important;
  padding: 10rpx 24rpx !important;
  font-size: 24rpx !important;
  font-weight: 700 !important;
}
.btn-secondary {
  background: rgba(201,169,110,0.16) !important;
  color: #f2dfb3 !important;
  border: 1rpx solid rgba(201,169,110,0.28) !important;
}
.btn-ghost {
  background: rgba(255,255,255,0.06) !important;
  color: #b9c4df !important;
  border: 1rpx solid rgba(255,255,255,0.1) !important;
}
.btn-secondary::after,
.btn-ghost::after { border: none; }

.list { max-height: calc(100vh - 200rpx); display: flex; flex-direction: column; gap: 20rpx; }

.zone-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4);
}
.zone-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.zone-title { font-size: 32rpx; font-weight: 800; color: #d4b87a; }
.zone-count { font-size: 24rpx; color: #99a8c8; }

.qr-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }

.qr-cell { text-align: center; position: relative; }
.select-chip {
  width: 88rpx;
  margin: 0 auto 8rpx;
  padding: 4rpx 0;
  border-radius: 999rpx;
  font-size: 18rpx;
  color: #9ea7bb;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.08);
}
.select-chip.is-selected {
  color: #23180f;
  background: linear-gradient(135deg, #e8d4a0, #d4b87a);
  border-color: rgba(232,212,160,0.5);
}
.qr-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #ffffff; margin: 0 auto; display: block; }
.qr-img-selected { box-shadow: 0 0 0 3rpx rgba(212,184,122,0.55); }
.qr-placeholder { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: rgba(232,224,212,0.06); border: 1rpx dashed rgba(201,169,110,0.14); margin: 0 auto; display: flex; align-items: center; justify-content: center; }
.qr-placeholder-selected { border-color: rgba(232,212,160,0.55); background: rgba(201,169,110,0.12); }
.qr-placeholder-text { font-size: 28rpx; color: #6b5e50; font-weight: 700; }
.qr-label { display: block; margin-top: 6rpx; font-size: 22rpx; color: #99a8c8; }
.qr-error { display: block; margin-top: 4rpx; font-size: 18rpx; color: #ff8a8a; }
.qr-action {
  margin-top: 8rpx;
  width: 120rpx;
  background: rgba(255,255,255,0.08) !important;
  color: #edf1fb !important;
  border: 1rpx solid rgba(255,255,255,0.12) !important;
  border-radius: 999rpx !important;
  font-size: 20rpx !important;
  line-height: 1.6 !important;
}
.qr-action::after { border: none; }

.tip-bar { margin-top: 24rpx; text-align: center; padding: 16rpx; background: rgba(255,255,255,0.04); border-radius: 16rpx; }
.tip-text { font-size: 22rpx; color: #8a7e72; }
