page { background: #0d0d0d; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 0%, rgba(201,169,110,0.08), transparent 32%),
    radial-gradient(circle at 84% 10%, rgba(160,120,60,0.06), transparent 36%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; }
.ambient-a { width: 300rpx; height: 300rpx; right: -80rpx; top: 40rpx; background: radial-gradient(circle, rgba(255,255,255,0.10), rgba(201,169,110,0.08) 34%, transparent 72%); filter: blur(16rpx); }
.ambient-b { width: 360rpx; height: 360rpx; left: -140rpx; bottom: 100rpx; background: radial-gradient(circle, rgba(120,160,255,0.06), transparent 74%); filter: blur(26rpx); }

.hero { padding: 20rpx 4rpx 28rpx; }
.hero-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 24rpx 24rpx 6rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.07), rgba(201,169,110,0.04) 40%, rgba(120,160,255,0.04));
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display: block; margin-bottom: 14rpx; font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 800; }
.hero-title { display: block; font-size: 56rpx; line-height: 1.04; font-weight: 900; color: #eef2ff; margin-bottom: 16rpx; text-shadow: 0 8rpx 30rpx rgba(157,187,255,0.10); }
.hero-lens {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.28), rgba(255,255,255,0.10) 20%, rgba(201,169,110,0.18) 48%, rgba(120,160,255,0.08) 72%, transparent 100%);
  border: 1rpx solid rgba(255,255,255,0.14);
  box-shadow: inset 0 2rpx 10rpx rgba(255,255,255,0.12), 0 18rpx 40rpx rgba(0,0,0,0.28);
}
.hero-lens::before { content: ''; position: absolute; top: 18rpx; left: 18rpx; width: 56rpx; height: 28rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.04)); transform: rotate(-20deg); }

.hint { font-size: 24rpx; color: #99a8c8; }
.state { text-align: center; padding: 80rpx 24rpx; color: #8a7e72; font-size: 28rpx; }
.empty-state { text-align: center; padding: 120rpx 48rpx; }
.empty-title { display: block; font-size: 32rpx; color: #d4b87a; margin-bottom: 12rpx; }
.empty-desc { display: block; font-size: 26rpx; color: #8a7e72; }
.list { max-height: calc(100vh - 260rpx); display: flex; flex-direction: column; gap: 20rpx; }

.notice-card {
  margin: 0 0 20rpx 0;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(212, 184, 122, 0.10);
  border: 1rpx solid rgba(212, 184, 122, 0.35);
  display: flex;
  flex-direction: column;
}
.notice-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #d4b87a;
  margin-bottom: 8rpx;
}
.notice-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(232, 224, 212, 0.65);
}

.btn-add {
  margin: 0 0 24rpx 0;
  width: 100%;
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important;
  border: none !important;
  border-radius: 999rpx !important;
  padding: 12rpx 32rpx !important;
  font-size: 28rpx !important;
  font-weight: 800 !important;
}
.btn-add::after { border: none; }

.glass-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.glass-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(180deg, rgba(255,255,255,0.18), transparent 30%, transparent 72%, rgba(120,160,255,0.05)); pointer-events: none; }
.card-shine { position: absolute; top: -18rpx; left: 42rpx; width: 180rpx; height: 64rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0.02)); transform: rotate(-10deg); filter: blur(2rpx); }

.row { display: flex; align-items: center; justify-content: space-between; }
.row-top { margin-bottom: 16rpx; }

.name { flex: 1; font-size: 32rpx; font-weight: 800; color: #eef2ff; padding-right: 16rpx; }

.row-meta { margin-bottom: 20rpx; }
.meta { font-size: 26rpx; color: #99a8c8; }
.meta.roi { font-weight: 700; color: #f0dfb2; }

.row-actions { justify-content: center; gap: 18rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(201,169,110,0.08); flex-wrap: wrap; }

.pri-btn {
  min-width: 72rpx !important; padding: 0 20rpx !important; line-height: 60rpx !important; height: 60rpx !important;
  background: rgba(201,169,110,0.10) !important; color: #d4b87a !important;
  border: 1rpx solid rgba(201,169,110,0.24) !important; border-radius: 14rpx !important;
  font-size: 34rpx !important; font-weight: 800;
}
.pri-btn::after { border: none; }
.pri-label { width: 100%; text-align: center; font-size: 24rpx; color: #99a8c8; order: -1; }

.detail-block { display: flex; flex-wrap: wrap; gap: 6rpx; margin-top: 8rpx; padding-top: 8rpx; border-top: 1rpx solid rgba(201,169,110,0.06); }
.detail-block-label { font-size: 24rpx; color: #6b5e50; }
.detail-block-value { font-size: 24rpx; color: #eef2ff; }

.del-btn {
  min-width: 72rpx !important; padding: 0 20rpx !important; line-height: 60rpx !important; height: 60rpx !important;
  background: rgba(143,74,57,0.18) !important; color: #e7b09b !important;
  border: 1rpx solid rgba(194,123,95,0.28) !important; border-radius: 14rpx !important;
  font-size: 24rpx !important; font-weight: 700;
}
.del-btn::after { border: none; }

.type-selector { display: flex; gap: 16rpx; flex-wrap: wrap; }
.type-selector .type-option {
  flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx;
  background: rgba(232,224,212,0.06); color: #8a7e72; font-size: 26rpx;
  border: 1rpx solid rgba(201,169,110,0.1); min-width: 120rpx;
}
.type-selector .type-option.active {
  background: rgba(201,169,110,0.14); color: #d4b87a; border-color: rgba(201,169,110,0.32);
}

.form-picker { display: flex; align-items: center; }

/* Modal */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; }
.modal-backdrop { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(10px); }
.modal-content {
  position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
  width: 88%; max-width: 640rpx; max-height: 85vh; overflow-y: auto; overflow-x: hidden;
  background: linear-gradient(160deg, rgba(27,23,19,0.94), rgba(18,16,14,0.88));
  backdrop-filter: blur(30rpx) saturate(145%);
  -webkit-backdrop-filter: blur(30rpx) saturate(145%);
  border-radius: 32rpx; padding: 40rpx 36rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.5), inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.modal-kicker { display: block; margin-bottom: 12rpx; text-align: center; font-size: 18rpx; color: #c9a96e; letter-spacing: 5rpx; font-weight: 800; }
.modal-title { display: block; font-size: 36rpx; font-weight: 800; color: #d4b87a; text-align: center; margin-bottom: 32rpx; }

.form-group { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 24rpx; color: #6b5e50; margin-bottom: 10rpx; }
.form-input {
  background: rgba(232,224,212,0.06); border: 1rpx solid rgba(201,169,110,0.14);
  border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #e8e0d4;
}
.form-input::placeholder { color: rgba(232,224,212,0.3); }

.store-checks { display: flex; flex-direction: column; gap: 12rpx; }
.store-check { display: flex; align-items: center; gap: 12rpx; padding: 12rpx; border-radius: 12rpx; background: rgba(232,224,212,0.04); }
.store-check-box { width: 36rpx; height: 36rpx; border-radius: 8rpx; border: 2rpx solid rgba(201,169,110,0.24); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #0d0d0d; background: rgba(232,224,212,0.06); flex-shrink: 0; }
.store-check-box.checked { background: linear-gradient(135deg, #c9a96e, #d4b87a); border-color: #d4b87a; color: #0d0d0d; }
.store-check-name { font-size: 26rpx; color: #e8e0d4; }

.form-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn-cancel {
  flex: 1; background: rgba(232,224,212,0.06) !important; color: #8a7e72 !important;
  border: 1rpx solid rgba(201,169,110,0.12) !important; border-radius: 999rpx !important;
  font-size: 28rpx !important; height: 80rpx !important; line-height: 80rpx !important;
}
.btn-cancel::after { border: none; }
.btn-submit {
  flex: 1; background: linear-gradient(135deg, #c9a96e, #d4b87a) !important; color: #0d0d0d !important;
  border: none !important; border-radius: 999rpx !important;
  font-size: 28rpx !important; height: 80rpx !important; line-height: 80rpx !important;
  font-weight: 800 !important;
}
.btn-submit::after { border: none; }