page { background: #0d0d0d; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 0%, rgba(201,169,110,0.08), transparent 32%),
    radial-gradient(circle at 84% 10%, rgba(160,120,60,0.06), transparent 36%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; }
.ambient-a { width: 300rpx; height: 300rpx; right: -80rpx; top: 40rpx; background: radial-gradient(circle, rgba(255,255,255,0.10), rgba(201,169,110,0.08) 34%, transparent 72%); filter: blur(16rpx); }
.ambient-b { width: 360rpx; height: 360rpx; left: -140rpx; bottom: 100rpx; background: radial-gradient(circle, rgba(120,160,255,0.06), transparent 74%); filter: blur(26rpx); }

.hero { padding: 20rpx 4rpx 28rpx; }
.hero-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 24rpx 24rpx 6rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.07), rgba(201,169,110,0.04) 40%, rgba(120,160,255,0.04));
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display: block; margin-bottom: 14rpx; font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 800; }
.hero-title { display: block; font-size: 56rpx; line-height: 1.04; font-weight: 900; color: #eef2ff; margin-bottom: 16rpx; text-shadow: 0 8rpx 30rpx rgba(157,187,255,0.10); }
.hero-lens {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.28), rgba(255,255,255,0.10) 20%, rgba(201,169,110,0.18) 48%, rgba(120,160,255,0.08) 72%, transparent 100%);
  border: 1rpx solid rgba(255,255,255,0.14);
  box-shadow: inset 0 2rpx 10rpx rgba(255,255,255,0.12), 0 18rpx 40rpx rgba(0,0,0,0.28);
}
.hero-lens::before { content: ''; position: absolute; top: 18rpx; left: 18rpx; width: 56rpx; height: 28rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.04)); transform: rotate(-20deg); }

.hint { font-size: 24rpx; color: #99a8c8; }
.state { text-align: center; padding: 80rpx 24rpx; color: #8a7e72; font-size: 28rpx; }
.list { max-height: calc(100vh - 120rpx); display: flex; flex-direction: column; gap: 20rpx; }

.glass-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.glass-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(180deg, rgba(255,255,255,0.18), transparent 30%, transparent 72%, rgba(120,160,255,0.05)); pointer-events: none; }
.card-shine { position: absolute; top: -18rpx; left: 42rpx; width: 180rpx; height: 64rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0.02)); transform: rotate(-10deg); filter: blur(2rpx); }

.row { display: flex; align-items: center; justify-content: space-between; }
.row-top { margin-bottom: 16rpx; }

.name { flex: 1; font-size: 32rpx; font-weight: 800; color: #eef2ff; padding-right: 16rpx; }

.row-meta { margin-bottom: 20rpx; }
.meta { font-size: 26rpx; color: #99a8c8; }
.meta.roi { font-weight: 700; color: #f0dfb2; }

.row-actions { justify-content: center; gap: 18rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(201,169,110,0.08); flex-wrap: wrap; }

.pri-btn {
  min-width: 72rpx !important; padding: 0 20rpx !important; line-height: 60rpx !important; height: 60rpx !important;
  background: rgba(201,169,110,0.10) !important; color: #d4b87a !important;
  border: 1rpx solid rgba(201,169,110,0.24) !important; border-radius: 14rpx !important;
  font-size: 34rpx !important; font-weight: 800;
}
.pri-btn::after { border: none; }
.pri-label { width: 100%; text-align: center; font-size: 24rpx; color: #99a8c8; order: -1; }

.row-delete { justify-content: center; margin-top: 12rpx; padding-top: 14rpx; border-top: 1rpx solid rgba(180,80,50,0.08); }
.del-btn {
  min-width: 160rpx !important; padding: 0 28rpx !important; line-height: 56rpx !important; height: 56rpx !important;
  background: rgba(180,80,50,0.08) !important; color: #b86a50 !important;
  border: 1rpx solid rgba(180,80,50,0.18) !important; border-radius: 999rpx !important;
  font-size: 22rpx !important; font-weight: 600 !important;
}
.del-btn::after { border: none; }

.generator-section { margin-top: 32rpx; }
.generator-head {
  display: flex; align-items: center; gap: 18rpx; margin-bottom: 28rpx;
}
.generator-icon {
  width: 68rpx; height: 68rpx; line-height: 68rpx; text-align: center; flex: 0 0 auto;
  border-radius: 18rpx; font-size: 28rpx; font-weight: 900; color: #0d0d0d;
  background: linear-gradient(135deg, #c9a96e, #d4b87a);
  box-shadow: 0 8rpx 24rpx rgba(201,169,110,0.28);
}
.generator-info { flex: 1; min-width: 0; }
.section-title { display: block; font-size: 30rpx; font-weight: 800; color: #eef2ff; margin-bottom: 6rpx; }
.section-desc { display: block; font-size: 22rpx; color: #95a4c7; line-height: 1.5; }

.form-row { margin-bottom: 24rpx; }
.form-label { font-size: 22rpx; color: #95a4c7; margin-bottom: 10rpx; display: block; letter-spacing: 2rpx; font-weight: 700; }
.form-input {
  display: block; width: 100%; box-sizing: border-box;
  background: rgba(232,224,212,0.06); border: 1rpx solid rgba(201,169,110,0.14);
  border-radius: 16rpx; padding: 18rpx 20rpx; color: #e8e0d4; font-size: 26rpx;
}
.form-hint { display: block; margin-top: 8rpx; font-size: 20rpx; color: #6b7a9c; line-height: 1.5; }
.gen-btn {
  width: 100%; display: block;
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important; border: none !important; border-radius: 999rpx !important;
  font-size: 26rpx !important; height: 84rpx !important; line-height: 84rpx !important; font-weight: 800 !important;
  letter-spacing: 1rpx; box-shadow: 0 10rpx 32rpx rgba(201,169,110,0.2);
}
.gen-btn::after { border: none; }

.qr-preview { margin-top: 36rpx; }
.qr-card {
  position: relative; overflow: visible;
  border-radius: 24rpx;
  background: linear-gradient(160deg, #1a1713 0%, #10100d 50%, #1a1512 100%);
  border: 1rpx solid rgba(201,169,110,0.2);
  box-shadow: 0 24rpx 72rpx rgba(0,0,0,0.55), 0 0 0 1rpx rgba(201,169,110,0.06) inset;
  padding: 0;
}

/* 金色四角装饰 */
.qr-edge {
  position: absolute; width: 32rpx; height: 32rpx;
  border-color: #c9a96e; border-style: solid; z-index: 2;
}
.qr-edge--tl { top: 12rpx; left: 12rpx; border-width: 2rpx 0 0 2rpx; border-radius: 8rpx 0 0 0; }
.qr-edge--tr { top: 12rpx; right: 12rpx; border-width: 2rpx 2rpx 0 0; border-radius: 0 8rpx 0 0; }
.qr-edge--bl { bottom: 12rpx; left: 12rpx; border-width: 0 0 2rpx 2rpx; border-radius: 0 0 0 8rpx; }
.qr-edge--br { bottom: 12rpx; right: 12rpx; border-width: 0 2rpx 2rpx 0; border-radius: 0 0 8rpx 0; }

/* 顶部金色条纹 */
.qr-accent-stripe {
  height: 6rpx;
  background: linear-gradient(90deg, transparent 8%, #c9a96e 20%, #e8d5a0 35%, #c9a96e 50%, #e8d5a0 65%, #c9a96e 80%, transparent 92%);
  opacity: 0.7;
}

/* 品牌区 */
.qr-brand {
  padding: 28rpx 36rpx 8rpx;
  text-align: left;
}
.qr-brand-name {
  display: block;
  font-size: 36rpx; font-weight: 900;
  background: linear-gradient(180deg, #fff7df 0%, #f1dfb0 38%, #d9bb72 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-family: 'Avenir Next', 'SF Pro Display', 'PingFang SC', sans-serif;
}
.qr-brand-tag {
  display: block; margin-top: 6rpx;
  font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 700;
}

/* 二维码主体区 */
.qr-body {
  padding: 20rpx 36rpx 36rpx;
  display: flex; flex-direction: column; align-items: center;
}
.qr-border-wrap {
  padding: 6rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(201,169,110,0.35), rgba(201,169,110,0.08) 40%, rgba(201,169,110,0.20));
  box-shadow: 0 0 48rpx rgba(201,169,110,0.15);
  position: relative;
}
.qr-border-wrap::after {
  content: ''; position: absolute; inset: 1rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(201,169,110,0.08), transparent 50%, rgba(201,169,110,0.04));
  pointer-events: none;
}
.qr-code-area {
  position: relative; z-index: 1;
  padding: 0; border-radius: 14rpx;
  background: #ffffff;
  display: flex; align-items: center; justify-content: center;
}
.qr-img {
  display: block; width: 320rpx; height: 320rpx;
  border-radius: 14rpx; background: #ffffff;
}

.qr-meta {
  margin-top: 24rpx; text-align: center;
}
.qr-scene-label {
  display: block;
  font-size: 16rpx; color: #6b7a9c; letter-spacing: 4rpx; font-weight: 700; margin-bottom: 6rpx;
}
.qr-scene {
  display: block;
  font-size: 28rpx; font-weight: 800; color: #eef2ff; letter-spacing: 2rpx;
  font-family: 'SF Mono', 'Menlo', 'Courier New', monospace;
}
.qr-instruction {
  display: block; margin-top: 12rpx;
  font-size: 20rpx; color: #7f8ea8; line-height: 1.5;
}

.qr-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 20rpx; }
.qr-action-btn { margin-top: 0 !important; }
