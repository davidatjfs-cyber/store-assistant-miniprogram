/* 券模板管理 - 液态玻璃风格 */
page { background: #0a0a0a; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 32rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.top-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(255,255,255,0.4);
}

.btn-add {
  background: linear-gradient(135deg, #ff6a00, #ff8533) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 999rpx !important;
  padding: 12rpx 32rpx !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
}
.btn-add::after { border: none; }

.state { text-align: center; padding: 120rpx; color: #C0C0C0; font-size: 28rpx; }

.empty { text-align: center; padding: 160rpx 48rpx; }
.empty-title { display: block; font-size: 32rpx; color: #ffffff; margin-bottom: 12rpx; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }
.empty-desc { display: block; font-size: 26rpx; color: #B0B0B0; }

.list { display: flex; flex-direction: column; gap: 20rpx; }

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx; padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
}

.template-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx;
}

.template-info { flex: 1; }
.template-name { display: block; font-size: 32rpx; font-weight: 700; color: #ffffff; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }
.template-type { display: block; font-size: 22rpx; color: #ff9a5c; margin-top: 4rpx; }

.template-details { border-top: 1rpx solid rgba(255,255,255,0.08); padding-top: 16rpx; }
.detail-row { display: flex; justify-content: space-between; padding: 8rpx 0; }
.detail-label { font-size: 24rpx; color: #B0B0B0; }
.detail-value { font-size: 24rpx; color: #E8E8E8; font-weight: 500; }

.template-actions {
  display: flex; gap: 16rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.08);
}

.action-btn {
  flex: 1; background: rgba(255,255,255,0.08) !important; color: #ffffff !important;
  border: 1rpx solid rgba(255,255,255,0.15) !important; border-radius: 16rpx !important;
  font-size: 26rpx !important; height: 64rpx !important; line-height: 64rpx !important;
}
.action-btn::after { border: none; }
.action-btn--danger { background: rgba(255,59,48,0.2) !important; color: #ff6b6b !important; border-color: rgba(255,59,48,0.3) !important; }

/* 弹窗 */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; }
.modal-backdrop { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(10px); }

.modal-content {
  position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
  width: 88%; max-width: 640rpx; max-height: 85vh; overflow-y: auto;
  background: linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
  backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
  border-radius: 32rpx; padding: 40rpx 36rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.5);
}

.modal-title {
  display: block; font-size: 36rpx; font-weight: 700; color: #ffffff;
  text-align: center; margin-bottom: 32rpx; text-shadow: 0 0 12rpx rgba(255,255,255,0.5);
}

.form-group { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 24rpx; color: #B0B0B0; margin-bottom: 10rpx; }

.form-input {
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #ffffff;
}
.form-input::placeholder { color: rgba(255,255,255,0.3); }

.form-textarea {
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #ffffff;
  height: 120rpx;
}
.form-textarea::placeholder { color: rgba(255,255,255,0.3); }

.type-selector { display: flex; gap: 16rpx; }
.type-option {
  flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx;
  background: rgba(255,255,255,0.06); color: #B0B0B0; font-size: 26rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.type-option.active {
  background: rgba(255,106,0,0.2); color: #ff9a5c; border-color: rgba(255,106,0,0.4);
}

.form-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn-cancel {
  flex: 1; background: rgba(255,255,255,0.08) !important; color: #B0B0B0 !important;
  border: 1rpx solid rgba(255,255,255,0.15) !important; border-radius: 999rpx !important;
  font-size: 28rpx !important; height: 80rpx !important; line-height: 80rpx !important;
}
.btn-cancel::after { border: none; }

.btn-submit {
  flex: 1; background: linear-gradient(135deg, #ff6a00, #ff8533) !important; color: #ffffff !important;
  border: none !important; border-radius: 999rpx !important;
  font-size: 28rpx !important; height: 80rpx !important; line-height: 80rpx !important;
  font-weight: 600 !important;
}
.btn-submit::after { border: none; }
