page { background: #0d0d0d; }
.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 0%, rgba(201,169,110,0.08), transparent 32%),
    radial-gradient(circle at 84% 10%, rgba(160,120,60,0.06), transparent 36%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
}

.top-bar { display: flex; flex-direction: column; align-items: stretch; justify-content: space-between; gap: 20rpx; margin-bottom: 24rpx; }
.top-copy { flex: 1; }
.top-title { font-size: 44rpx; font-weight: 800; color: #d4b87a; }
.top-title::before { content: 'CUSTOMER RELATIONS'; display: block; margin-bottom: 14rpx; font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 800; }
.top-subtitle { display: block; margin-top: 14rpx; font-size: 24rpx; line-height: 1.55; color: #8a7e72; }

.search-box { flex: 1; max-width: none; margin-left: 0; }
.search-input {
  background: rgba(232,224,212,0.06); border: 1rpx solid rgba(201,169,110,0.14);
  border-radius: 999rpx; padding: 14rpx 24rpx; font-size: 24rpx; color: #e8e0d4;
}
.search-input::placeholder { color: rgba(232,224,212,0.3); }

.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 24rpx; }
.stats-grid .stat-card:last-child { grid-column: 1 / -1; }
.stat-card {
  background: rgba(201,169,110,0.05); border-radius: 20rpx; padding: 24rpx 16rpx; text-align: center;
  border: 1rpx solid rgba(201,169,110,0.08);
}
.stat-value { display: block; font-size: 40rpx; font-weight: 800; color: #d4b87a; }
.stat-label { display: block; font-size: 22rpx; color: #8a7e72; margin-top: 4rpx; }

.state { text-align: center; padding: 120rpx; color: #8a7e72; font-size: 28rpx; }
.list { display: flex; flex-direction: column; gap: 16rpx; }

.glass-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.glass-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(180deg, rgba(255,255,255,0.12), transparent 34%, transparent 72%, rgba(201,169,110,0.06)); pointer-events: none; }

.customer-header { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.customer-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx;
  background: linear-gradient(135deg, rgba(201,169,110,0.3), rgba(212,184,122,0.18));
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid rgba(201,169,110,0.22);
}
.avatar-text { font-size: 24rpx; font-weight: 800; color: #d4b87a; }

.customer-info { flex: 1; }
.customer-kicker { display: block; margin-bottom: 8rpx; font-size: 18rpx; color: #6b5e50; letter-spacing: 4rpx; font-weight: 800; }
.customer-name-row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.customer-phone { font-size: 28rpx; font-weight: 800; color: #e8e0d4; }
.customer-join { font-size: 22rpx; color: #8a7e72; margin-top: 4rpx; }

.level-tag { font-size: 20rpx; font-weight: 700; padding: 4rpx 12rpx; border-radius: 8rpx; }
.level-tag--vip { background: linear-gradient(135deg, #c9a96e, #d4b87a); color: #0d0d0d; }
.level-tag--active { background: rgba(201,169,110,0.10); color: #d4b87a; border: 1rpx solid rgba(201,169,110,0.16); }
.level-tag--new { background: rgba(232,224,212,0.08); color: #8a7e72; }
.level-tag--prospect { background: rgba(148,163,184,0.10); color: #94a3b8; border: 1rpx solid rgba(148,163,184,0.16); }
.level-tag--at_risk { background: rgba(240,179,90,0.10); color: #f0b35a; border: 1rpx solid rgba(240,179,90,0.16); }
.level-tag--dormant { background: rgba(217,118,118,0.10); color: #d97676; border: 1rpx solid rgba(217,118,118,0.16); }
.level-tag--churned { background: rgba(183,172,161,0.10); color: #b7aca1; border: 1rpx solid rgba(183,172,161,0.16); }

.customer-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; border-top: 1rpx solid rgba(201,169,110,0.08); padding-top: 16rpx; }
.customer-stat { text-align: center; }
.c-stat-value { display: block; font-size: 26rpx; font-weight: 800; color: #e8e0d4; }
.c-stat-label { display: block; font-size: 20rpx; color: #6b5e50; margin-top: 2rpx; }

.action-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(201,169,110,0.12);
}
.send-btn {
  width: 100% !important;
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important;
  border: none !important;
  border-radius: 999rpx !important;
  font-size: 24rpx !important;
  height: 68rpx !important;
  line-height: 68rpx !important;
  font-weight: 800 !important;
}
.send-btn::after { border: none; }

.store-switch {
  display: flex;
  padding: 6rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: rgba(232,224,212,0.05);
  border: 1rpx solid rgba(201,169,110,0.14);
}
.store-switch-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #8a7e72;
  transition: color 0.2s ease;
}
.store-switch-item--active {
  color: #0d0d0d;
  font-weight: 800;
  background: linear-gradient(135deg, #c9a96e, #d4b87a);
  box-shadow: 0 6rpx 16rpx rgba(201,169,110,0.28);
}

/* 标签筛选 chips */
.tag-bar { white-space: nowrap; margin-bottom: 20rpx; }
.tag-chip {
  display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 999rpx; font-size: 24rpx; color: #8a7e72;
  background: rgba(232,224,212,0.05); border: 1rpx solid rgba(201,169,110,0.14);
}
.tag-chip--active {
  color: #0d0d0d; font-weight: 800;
  background: linear-gradient(135deg, #c9a96e, #d4b87a);
  border-color: transparent;
}

/* 批量操作工具条 */
.batch-bar { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.batch-toggle {
  padding: 12rpx 26rpx; border-radius: 999rpx; font-size: 24rpx; color: #d4b87a;
  background: rgba(201,169,110,0.08); border: 1rpx solid rgba(201,169,110,0.22);
}
.batch-toggle--on { color: #0d0d0d; font-weight: 800; background: linear-gradient(135deg, #c9a96e, #d4b87a); }
.batch-action { font-size: 24rpx; color: #8a7e72; padding: 12rpx 8rpx; }
.batch-count { font-size: 24rpx; color: #d4b87a; margin-left: auto; }
.batch-send {
  padding: 12rpx 30rpx; border-radius: 999rpx; font-size: 24rpx; font-weight: 800; color: #0d0d0d;
  background: linear-gradient(135deg, #c9a96e, #d4b87a);
}
.batch-send--disabled { opacity: 0.4; }

/* 选择态 */
.customer-item--checked { border-color: rgba(201,169,110,0.5); box-shadow: 0 0 0 2rpx rgba(201,169,110,0.4), 0 20rpx 60rpx rgba(0,0,0,0.4); }
.select-dot {
  width: 40rpx; height: 40rpx; border-radius: 50%; margin-right: 16rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #0d0d0d; font-weight: 800;
  border: 2rpx solid rgba(201,169,110,0.4); background: rgba(232,224,212,0.04);
}
.select-dot--on { background: linear-gradient(135deg, #c9a96e, #d4b87a); border-color: transparent; }
