page { background: #0a0a0a; }
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 32rpx;
}

.top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.top-title { font-size: 44rpx; font-weight: 800; color: #ffffff; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }

.search-box { flex: 1; max-width: 300rpx; margin-left: 20rpx; }
.search-input {
  background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 999rpx; padding: 12rpx 24rpx; font-size: 24rpx; color: #ffffff;
}
.search-input::placeholder { color: rgba(255,255,255,0.3); }

.stats-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; margin-bottom: 24rpx; }
.stat-card {
  background: rgba(255,255,255,0.06); border-radius: 20rpx; padding: 24rpx 16rpx; text-align: center;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.stat-value { display: block; font-size: 40rpx; font-weight: 800; color: #ffffff; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }
.stat-label { display: block; font-size: 22rpx; color: #B0B0B0; margin-top: 4rpx; }

.state { text-align: center; padding: 120rpx; color: #C0C0C0; font-size: 28rpx; }
.list { display: flex; flex-direction: column; gap: 16rpx; }

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx; padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
}

.customer-header { display: flex; align-items: center; margin-bottom: 20rpx; }
.customer-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx;
  background: linear-gradient(135deg, rgba(255,106,0,0.3), rgba(255,133,51,0.2));
  display: flex; align-items: center; justify-content: center;
  border: 1rpx solid rgba(255,106,0,0.3);
}
.avatar-text { font-size: 24rpx; font-weight: 700; color: #ff9a5c; }

.customer-info { flex: 1; }
.customer-name-row { display: flex; align-items: center; gap: 12rpx; }
.customer-phone { font-size: 28rpx; font-weight: 600; color: #ffffff; }
.customer-join { font-size: 22rpx; color: #B0B0B0; margin-top: 4rpx; }

.level-tag { font-size: 20rpx; font-weight: 700; padding: 4rpx 12rpx; border-radius: 8rpx; }
.level-tag--vip { background: linear-gradient(135deg, #ff6a00, #ff8533); color: #fff; }
.level-tag--active { background: linear-gradient(135deg, #00b894, #00cec9); color: #fff; }
.level-tag--new { background: rgba(255,255,255,0.1); color: #B0B0B0; }

.customer-stats { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12rpx; border-top: 1rpx solid rgba(255,255,255,0.08); padding-top: 16rpx; }
.customer-stat { text-align: center; }
.c-stat-value { display: block; font-size: 26rpx; font-weight: 700; color: #E8E8E8; }
.c-stat-label { display: block; font-size: 20rpx; color: #888888; margin-top: 2rpx; }

.action-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(255,255,255,0.1);
}
.send-btn {
  width: 100% !important;
  background: linear-gradient(90deg, #ff6a00, #ff8533) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 12rpx !important;
  font-size: 24rpx !important;
  height: 56rpx !important;
  line-height: 56rpx !important;
}
.send-btn::after { border: none; }
