<view class="page">
  <view class="top-bar">
    <view class="top-copy">
      <text class="top-title">客户管理</text>
      <text class="top-subtitle">查看会员分层、消费趋势与定向发券入口</text>
    </view>
    <view class="search-box">
      <input class="search-input" placeholder="搜索手机号/姓名" value="{{keyword}}" bindinput="onSearch" />
    </view>
  </view>

  <!-- 门店切换（仅管理员） -->
  <view class="store-switch" wx:if="{{isAdmin}}">
    <view
      class="store-switch-item {{selectedStoreId === item.id ? 'store-switch-item--active' : ''}}"
      wx:for="{{storeTabs}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onSelectStore"
    >{{item.name}}</view>
  </view>

  <!-- 标签筛选（与 HRMS 同步的客户标签） -->
  <scroll-view class="tag-bar" scroll-x wx:if="{{availableTags.length}}">
    <view
      class="tag-chip {{selectedTag === '' ? 'tag-chip--active' : ''}}"
      data-tag=""
      bindtap="onSelectTag"
    >全部</view>
    <view
      class="tag-chip {{selectedTag === item.key ? 'tag-chip--active' : ''}}"
      wx:for="{{availableTags}}"
      wx:key="key"
      data-tag="{{item.key}}"
      bindtap="onSelectTag"
    >{{item.label}}</view>
  </scroll-view>

  <!-- 自定义日期范围查询新增客户 -->
  <view class="date-bar">
    <picker mode="date" value="{{startDate}}" end="{{endDate || ''}}" bindchange="onStartDateChange">
      <view class="date-field {{startDate ? 'date-field--set' : ''}}">{{startDate || '开始日期'}}</view>
    </picker>
    <text class="date-sep">至</text>
    <picker mode="date" value="{{endDate}}" start="{{startDate || ''}}" bindchange="onEndDateChange">
      <view class="date-field {{endDate ? 'date-field--set' : ''}}">{{endDate || '结束日期'}}</view>
    </picker>
    <view class="date-clear {{(startDate || endDate) ? '' : 'date-clear--disabled'}}" bindtap="onClearDateRange">清除</view>
  </view>

  <!-- 批量操作工具条（仅管理员） -->
  <view class="batch-bar" wx:if="{{isAdmin}}">
    <view class="batch-toggle {{selectMode ? 'batch-toggle--on' : ''}}" bindtap="onToggleSelectMode">
      {{selectMode ? '退出批量' : '批量发券'}}
    </view>
    <block wx:if="{{selectMode}}">
      <view class="batch-action" bindtap="onSelectAll">全选/反选</view>
      <view class="batch-count">已选 {{selectedCount}}</view>
      <view class="batch-send {{selectedCount ? '' : 'batch-send--disabled'}}" bindtap="onBatchSend">发券</view>
    </block>
  </view>

  <!-- 统计概览 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalUsers}}</text>
      <text class="stat-label">总用户数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.vipUsers}}</text>
      <text class="stat-label">VIP用户</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.newUsers}}</text>
      <text class="stat-label">{{stats.newUsersLabel || '本月新增'}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="state"><text>加载中</text></view>

  <!-- 客户列表 -->
  <view wx:else class="list">
    <view
      class="glass-card customer-item {{item._checked ? 'customer-item--checked' : ''}}"
      wx:for="{{customers}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onToggleCustomer"
    >
      <view class="customer-header">
        <view class="select-dot {{item._checked ? 'select-dot--on' : ''}}" wx:if="{{selectMode}}">{{item._checked ? '✓' : ''}}</view>
        <view class="customer-avatar">
          <text class="avatar-text">{{item.phone ? item.phone.slice(-4) : '??'}}</text>
        </view>
        <view class="customer-info">
          <text class="customer-kicker">CUSTOMER PROFILE</text>
          <view class="customer-name-row">
            <text class="customer-realname" wx:if="{{item.title}}">{{item.title}}</text>
            <text class="customer-phone">{{item.phone || '未授权'}}</text>
            <text class="level-tag level-tag--{{item.user_level || 'prospect'}}">{{item.user_level_label || '潜在新客'}}</text>
          </view>
          <text class="customer-join">加入于 {{item.joinDate || '—'}}{{item.genderLabel ? ' · ' + item.genderLabel : ''}}</text>
        </view>
      </view>
      <view class="customer-stats">
        <view class="customer-stat">
          <text class="c-stat-value">{{item.totalOrders || 0}}</text>
          <text class="c-stat-label">订单</text>
        </view>
        <view class="customer-stat">
          <text class="c-stat-value">{{item.totalSpentText}}</text>
          <text class="c-stat-label">消费</text>
        </view>
        <view class="customer-stat">
          <text class="c-stat-value">{{item.voucherCount || 0}}</text>
          <text class="c-stat-label">持券</text>
        </view>
        <view class="customer-stat">
          <text class="c-stat-value">{{item.lastVisit || '—'}}</text>
          <text class="c-stat-label">最近到店</text>
        </view>
      </view>
      <view class="action-row" wx:if="{{!selectMode}}">
        <button class="profile-btn" size="mini" data-id="{{item._id}}" data-phone="{{item.phone}}" data-surname="{{item.surname}}" data-gender="{{item.gender}}" catchtap="openProfileEdit">
          {{item.title ? '✎ 修改姓名/性别' : '✎ 补全姓名/性别'}}
        </button>
        <button wx:if="{{isAdmin}}" class="send-btn" size="mini" data-id="{{item._id}}" catchtap="onSendVoucher">
          🎁 赠送优惠券
        </button>
      </view>
    </view>
  </view>

  <!-- 补全资料弹窗（姓名/性别）-->
  <view class="profile-modal" wx:if="{{profileEditVisible}}" catchtap="noop">
    <view class="profile-backdrop" bindtap="closeProfileEdit"></view>
    <view class="profile-card" catchtap="noop">
      <text class="profile-kicker">完善顾客资料</text>
      <text class="profile-name">{{editName || '该顾客'}}</text>
      <view class="field">
        <text class="field-label">姓（如「张」，复姓可填2字）</text>
        <input class="field-input" maxlength="-1" placeholder="请输入中文姓氏" value="{{editSurname}}" bindinput="onSurnameInput" />
      </view>
      <view class="field">
        <text class="field-label">性别</text>
        <view class="gender-row">
          <text class="gender-opt {{editGender === 'male' ? 'gender-opt--on' : ''}}" data-gender="male" bindtap="selectGender">先生</text>
          <text class="gender-opt {{editGender === 'female' ? 'gender-opt--on' : ''}}" data-gender="female" bindtap="selectGender">女士</text>
        </view>
      </view>
      <button class="profile-save" loading="{{profileSaving}}" disabled="{{profileSaving}}" bindtap="saveProfile">保存</button>
      <text class="profile-cancel" bindtap="closeProfileEdit">取消</text>
    </view>
  </view>
</view>
