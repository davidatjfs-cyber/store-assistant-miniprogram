<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>
  <view class="hero">
    <view class="hero-shell">
      <view class="hero-copy">
        <text class="hero-kicker">MARKETING OPS</text>
        <text class="hero-title">营销规则</text>
        <view class="hint" wx:if="{{statsDate}}">今日 ROI 统计日：{{statsDate}}（上海）</view>
      </view>
      <view class="hero-lens"></view>
    </view>
  </view>

  <!-- 营销规则的管理（新增/编辑/删除/启停）已统一收归 HRMS 后台，小程序仅作只读展示 -->
  <view class="notice-card">
    <text class="notice-title">营销规则统一在 HRMS 管理</text>
    <text class="notice-desc">支付后发券、召回触达等所有营销触发规则均在 HRMS 后台集中配置（统一审核与频控），本页仅展示当前生效规则，约每 2 分钟从 HRMS 同步一次。如需新增 / 修改 / 删除，请前往 HRMS「增长 → 自动营销 → 支付发券」。</text>
  </view>

  <view wx:if="{{loading}}" class="state">加载中…</view>

  <view wx:elif="{{!rules.length}}" class="empty-state">
    <text class="empty-title">暂无营销规则</text>
    <text class="empty-desc">请在 HRMS 后台配置营销规则，生效后将在此展示</text>
  </view>

  <scroll-view wx:else scroll-y class="list">
    <view class="glass-card rule-card" wx:for="{{rules}}" wx:key="rule_id">
      <view class="card-shine"></view>
      <view class="row row-top">
        <text class="name">{{item.name || item.rule_id}}</text>
        <text class="status-badge {{item.active ? 'status-on' : 'status-off'}}">{{item.active ? '启用中' : '已停用'}}</text>
      </view>
      <view class="row row-meta">
        <text class="meta">{{item.storeName}}</text>
        <text class="meta">{{item.triggerLabel}}</text>
      </view>
      <view class="row row-meta">
        <text class="meta">优先级 {{item.priority}}</text>
        <text class="meta roi">ROI {{item.roiText}}</text>
      </view>
      <view class="detail-block" wx:if="{{item.tagLabel}}">
        <text class="detail-block-label">目标人群：</text>
        <text class="detail-block-value">{{item.tagLabel}}</text>
      </view>
      <view class="detail-block" wx:if="{{item.triggerValDisplay}}">
        <text class="detail-block-label">触发条件：</text>
        <text class="detail-block-value">{{item.triggerValDisplay}}</text>
      </view>
      <view class="detail-block" wx:if="{{item.template_id}}">
        <text class="detail-block-label">关联券模板：</text>
        <text class="detail-block-value">{{item.templateName || item.template_id}}</text>
      </view>
      <view class="detail-block" wx:if="{{item.daily_user_limit != null || item.global_daily_limit != null}}">
        <text class="detail-block-label">限额：</text>
        <text class="detail-block-value">{{item.daily_user_limit != null ? '每人' + item.daily_user_limit + '次/天' : ''}}{{item.global_daily_limit != null ? ' 全局' + item.global_daily_limit + '张/天' : ''}}</text>
      </view>
    </view>
  </scroll-view>
</view>
