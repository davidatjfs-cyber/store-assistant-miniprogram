.container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 28rpx;
  color: #666;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn.primary {
  background: #07c160;
  color: #fff;
}

.btn.secondary {
  background: #f0f0f0;
  color: #333;
}

.result {
  background: #e8f5e9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.result.error {
  background: #ffebee;
}

.success {
  color: #2e7d32;
  font-size: 28rpx;
}

.result.error text {
  color: #c62828;
  font-size: 28rpx;
}

.hint {
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.hint text {
  color: #e65100;
  font-size: 24rpx;
  line-height: 1.6;
}
