page { background: #0d0d0d; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 0%, rgba(201,169,110,0.08), transparent 30%),
    radial-gradient(circle at 82% 10%, rgba(160,120,60,0.06), transparent 34%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; }
.ambient-a { width: 280rpx; height: 280rpx; right: -80rpx; top: 40rpx; background: radial-gradient(circle, rgba(255,255,255,0.12), rgba(201,169,110,0.08) 30%, transparent 72%); filter: blur(14rpx); }
.ambient-b { width: 320rpx; height: 320rpx; left: -120rpx; bottom: 120rpx; background: radial-gradient(circle, rgba(120,160,255,0.06), transparent 74%); filter: blur(24rpx); }

.state { text-align: center; padding: 140rpx 32rpx; color: #8a7e72; font-size: 28rpx; }

.glass-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 36rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.glass-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(180deg, rgba(255,255,255,0.18), transparent 30%, transparent 72%, rgba(120,160,255,0.05)); pointer-events: none; }

.linked-section .status-card {
  text-align: center;
  padding: 36rpx 32rpx;
}

.status-icon { font-size: 48rpx; display: block; margin-bottom: 12rpx; }
.status-title { font-size: 32rpx; font-weight: 800; color: #d4b87a; display: block; }
.status-desc { font-size: 24rpx; color: #99a8c8; display: block; margin-top: 8rpx; }

.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 800; color: #d4b87a; }

.empty-card { text-align: center; }
.empty-text { color: #8a7e72; font-size: 28rpx; }

.voucher-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voucher-info { flex: 1; }
.voucher-name { font-size: 28rpx; font-weight: 700; color: #e8e0d4; display: block; margin-bottom: 6rpx; }
.voucher-amount { font-size: 32rpx; color: #d4b87a; font-weight: 800; display: block; }

.send-btn {
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important;
  border-radius: 999rpx !important;
  font-size: 24rpx !important;
  padding: 0 28rpx !important;
  font-weight: 800 !important;
  border: none;
}
.send-btn::after { border: none; }

.unlinked-section { padding-top: 60rpx; }

.link-card {
  text-align: center;
  padding: 60rpx 32rpx;
}

.link-icon { font-size: 72rpx; display: block; margin-bottom: 24rpx; }
.link-title { font-size: 36rpx; font-weight: 800; color: #eef2ff; display: block; margin-bottom: 12rpx; }
.link-desc { font-size: 28rpx; color: #99a8c8; display: block; margin-bottom: 40rpx; line-height: 1.6; }

.link-btn {
  background: linear-gradient(135deg, #c9a96e, #d4b87a) !important;
  color: #0d0d0d !important;
  border-radius: 999rpx !important;
  font-size: 32rpx !important;
  width: 400rpx !important;
  font-weight: 800 !important;
  border: none;
}
.link-btn::after { border: none; }