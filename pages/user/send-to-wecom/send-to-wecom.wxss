.page { padding: 24rpx; }

.state { text-align: center; color: #999; padding: 40rpx 0; }

.glass-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.linked-section .status-card {
  text-align: center;
  padding: 36rpx 32rpx;
}

.status-icon { font-size: 48rpx; display: block; margin-bottom: 12rpx; }
.status-title { font-size: 32rpx; font-weight: bold; color: #52c41a; display: block; }
.status-desc { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }

.section-header { margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: bold; }

.empty-card { text-align: center; }
.empty-text { color: #999; font-size: 28rpx; }

.voucher-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voucher-info { flex: 1; }
.voucher-name { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 6rpx; }
.voucher-amount { font-size: 32rpx; color: #ff4d4f; font-weight: bold; display: block; }

.send-btn {
  background: #07c160;
  color: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  padding: 0 28rpx;
  border: none;
}

.unlinked-section { padding-top: 60rpx; }

.link-card {
  text-align: center;
  padding: 60rpx 32rpx;
}

.link-icon { font-size: 72rpx; display: block; margin-bottom: 24rpx; }
.link-title { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 12rpx; }
.link-desc { font-size: 28rpx; color: #666; display: block; margin-bottom: 40rpx; line-height: 1.6; }

.link-btn {
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  width: 400rpx;
  border: none;
}