<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>

  <view wx:if="{{loading}}" class="state">企微状态加载中…</view>

  <block wx:elif="{{!wecomAvailable}}">
    <view class="hero-card">
      <text class="hero-kicker">ENTERPRISE WECHAT</text>
      <text class="hero-title">当前门店暂未开通企微礼遇</text>
      <text class="hero-desc">你仍然可以先入会和点餐，企微接券开通后会自动同步。</text>
    </view>
  </block>

  <block wx:elif="{{wecomLinked}}">
    <view class="hero-card linked-hero">
      <view class="hero-copy">
        <text class="hero-kicker">ENTERPRISE WECHAT</text>
        <text class="hero-title">已关联企业微信</text>
        <text class="hero-desc" wx:if="{{wecomInfo.external_userid}}">企微 ID：{{wecomInfo.external_userid}}</text>
      </view>
      <view class="hero-badge">已连接</view>
    </view>

    <view wx:if="{{!vouchers.length}}" class="empty-card">
      <text class="empty-title">暂无可发送的优惠券</text>
      <text class="empty-desc">当你的券包里有可发送礼遇时，这里会同步出现。</text>
    </view>

    <view wx:else class="voucher-list">
      <view class="voucher-card" wx:for="{{vouchers}}" wx:key="_id">
        <view class="voucher-copy">
          <text class="voucher-kicker">{{item.amountText}}</text>
          <text class="voucher-name">{{item.displayName}}</text>
        </view>
        <button class="send-btn" size="mini" data-voucher-id="{{item._id}}" bindtap="sendToWecom">发送到企微</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="hero-card">
      <text class="hero-kicker">ENTERPRISE WECHAT</text>
      <text class="hero-title">关联企业微信</text>
      <text class="hero-desc">关联后可在企业微信中接收优惠券和活动通知。</text>
      <button class="link-btn" bindtap="associateWecom">立即关联</button>
    </view>
  </block>

  <view wx:if="{{dialogVisible}}" class="dialog-layer">
    <view class="dialog-backdrop" bindtap="hideDialog"></view>
    <view class="dialog-card">
      <image class="dialog-bg" src="../../../assets/guest-dining-reference.jpg" mode="aspectFill"></image>
      <view class="dialog-mask"></view>
      <view class="dialog-content">
      <view class="dialog-chip">礼遇确认</view>
      <text class="dialog-title">{{dialogTitle}}</text>
      <text class="dialog-desc">{{dialogDesc}}</text>
      <view class="dialog-actions">
        <button class="dialog-btn dialog-btn--ghost" bindtap="hideDialog">稍后再说</button>
        <button class="dialog-btn dialog-btn--primary" loading="{{confirmLoading}}" bindtap="confirmDialogAction">立即关联</button>
      </view>
      </view>
    </view>
  </view>
</view>
