/* 极简兼容版 */
.page {
  background-color: #f8f5f2;
  padding: 20rpx;
}

.debug {
  padding: 10rpx;
  background: #f0f0f0;
  margin: 5rpx;
  font-size: 24rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  padding: 40rpx;
  border-radius: 20rpx;
  width: 80%;
  max-width: 500rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  height: 80rpx;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  text-align: center;
}

.modal-btn {
  background: #FF6A00;
  color: white;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  height: 80rpx;
}

.legacy {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FF6A00;
  z-index: 1000;
}

.legacy-title {
  position: absolute;
  top: 40%;
  left: 0;
  right: 0;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
}

.legacy-points {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  color: white;
  font-size: 64rpx;
  font-weight: bold;
  text-align: center;
}
