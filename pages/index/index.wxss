/* 首页 - 液态玻璃 (高亮银色) */
page { background: #0a0a0a; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 0;
}

.landing { padding: 32rpx; padding-bottom: 48rpx; }

.hero-section { text-align: center; padding: 80rpx 24rpx 60rpx; }

.hero-mark {
  width: 120rpx; height: 120rpx; line-height: 120rpx;
  margin: 0 auto 28rpx; border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,106,0,0.8), rgba(255,133,51,0.6));
  color: #fff; font-size: 56rpx; font-weight: 700;
  box-shadow: 0 0 60rpx rgba(255,106,0,0.4), 0 0 120rpx rgba(255,106,0,0.2);
  border: 1rpx solid rgba(255,255,255,0.2);
}

.hero-title {
  display: block; font-size: 48rpx; font-weight: 700;
  color: #ffffff; letter-spacing: 4rpx; margin-bottom: 16rpx;
  text-shadow: 0 0 20rpx rgba(255,255,255,0.5);
}

.hero-subtitle {
  display: block; font-size: 24rpx;
  color: #D0D0D0; letter-spacing: 4rpx;
  text-shadow: 0 0 10rpx rgba(255,255,255,0.3);
}

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx; padding: 36rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.15);
}

.card-title {
  display: block; font-size: 34rpx; font-weight: 600;
  color: #ffffff; margin-bottom: 12rpx;
  text-shadow: 0 0 10rpx rgba(255,255,255,0.4);
}

.card-desc {
  display: block; font-size: 26rpx;
  color: #C0C0C0; line-height: 1.55; margin-bottom: 24rpx;
}

.card-meta { padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.1); }

.meta-row { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; }

.meta-label { font-size: 26rpx; color: #B0B0B0; }

.meta-value {
  font-size: 28rpx; color: #E8E8E8; font-weight: 500;
  text-shadow: 0 0 8rpx rgba(255,255,255,0.3);
}

.warn-card {
  border-color: rgba(255,106,0,0.3);
  background: linear-gradient(135deg, rgba(255,106,0,0.12), rgba(255,106,0,0.04));
}

.warn-title {
  display: block; font-size: 32rpx; font-weight: 600;
  color: #ff9a5c; margin-bottom: 12rpx;
  text-shadow: 0 0 12rpx rgba(255,106,0,0.5);
}

.warn-desc {
  display: block; font-size: 26rpx;
  color: #C0C0C0; line-height: 1.55;
}

.quick-area { margin-top: 16rpx; }

.quick-sec-title {
  display: block; font-size: 24rpx;
  color: #B0B0B0; margin: 32rpx 0 20rpx;
  letter-spacing: 2rpx; text-align: center;
}

.quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }

.glass-tile {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 220rpx; padding: 32rpx 16rpx; box-sizing: border-box;
  background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border-radius: 28rpx; border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2); text-decoration: none;
}

.glass-tile--hover {
  background: linear-gradient(135deg, rgba(255,106,0,0.2), rgba(255,106,0,0.1));
  border-color: rgba(255,106,0,0.3);
}

.quick-icon {
  width: 88rpx; height: 88rpx; line-height: 88rpx; text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255,106,0,0.6), rgba(255,133,51,0.4));
  color: #fff; font-size: 36rpx; font-weight: 800;
  margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(255,106,0,0.3);
}

.quick-title {
  font-size: 30rpx; font-weight: 600; color: #ffffff; text-align: center; margin-bottom: 8rpx;
  text-shadow: 0 0 8rpx rgba(255,255,255,0.4);
}

.quick-sub { font-size: 22rpx; color: #B0B0B0; text-align: center; }

.reauth-wrap { margin-top: 32rpx; text-align: center; padding: 0 32rpx; }
.reauth-hint { display: block; font-size: 24rpx; color: #B0B0B0; margin-bottom: 20rpx; }

.modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999;
}

.modal-backdrop {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}

.glass-modal {
  position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
  width: 84%; max-width: 600rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
  backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
  border-radius: 32rpx; padding: 48rpx 36rpx;
  box-shadow: 0 16rpx 64rpx rgba(0,0,0,0.5), inset 0 1rpx 0 rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.15); text-align: center;
}

.modal-badge {
  display: inline-block; font-size: 22rpx; color: #ff9a5c;
  background: rgba(255,106,0,0.15); padding: 8rpx 20rpx;
  border-radius: 999rpx; margin-bottom: 24rpx;
}

.modal-title {
  font-size: 40rpx; font-weight: 700; color: #ffffff; margin-bottom: 16rpx;
  text-shadow: 0 0 12rpx rgba(255,255,255,0.5);
}

.modal-desc {
  font-size: 26rpx; color: #C0C0C0; line-height: 1.6; margin-bottom: 36rpx;
}

.modal-foot { margin-top: 24rpx; font-size: 22rpx; color: #888888; }

.legacy {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(160deg, rgba(255,106,0,0.9), rgba(255,133,51,0.8));
  z-index: 1000; display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
}

.legacy-inner { text-align: center; padding: 48rpx; }
.legacy-title { color: #fff; font-size: 48rpx; font-weight: 700; margin-bottom: 16rpx; }
.legacy-sub { color: rgba(255,255,255,0.85); font-size: 28rpx; margin-bottom: 24rpx; }
.legacy-points { color: #fff; font-size: 72rpx; font-weight: 700; text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2); }
