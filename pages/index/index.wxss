page {
  background: #090707;
  color: #f6ecdf;
}

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background: #090707;
}

.hero-bg-shell,
.page-bg,
.page-mask,
.page-vignette {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
}

.hero-bg-shell {
  height: 760rpx;
  overflow: hidden;
}

.page-bg {
  width: 100%;
  height: 760rpx;
  display: block;
  filter: saturate(1.08) brightness(1.06);
}

.page-mask {
  bottom: 0;
  background:
    linear-gradient(180deg, rgba(7,5,5,0.08) 0%, rgba(12,8,8,0.01) 24%, rgba(12,8,8,0.00) 44%, rgba(8,6,6,0.08) 100%);
}

.page-vignette {
  bottom: 0;
  background:
    radial-gradient(circle at 71% 29%, rgba(243,174,123,0.10), transparent 12%),
    radial-gradient(circle at 78% 24%, rgba(255,219,162,0.05), transparent 10%);
}

.page-shell,
.reauth-wrap,
.icp-footer {
  position: relative;
  z-index: 1;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 34rpx 48rpx;
  box-sizing: border-box;
}

.brand-head {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 18rpx;
  min-height: 52rpx;
}

.brand-title {
  margin: 0 auto;
  padding-left: 92rpx;
  font-size: 28rpx;
  color: #f8f2ea;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.brand-status {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(22,18,17,0.74);
  border: 1rpx solid rgba(255,255,255,0.10);
}

.brand-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #80ff58;
  box-shadow: 0 0 10rpx rgba(128,255,88,0.42);
}

.brand-status-text {
  font-size: 22rpx;
  color: #f3ece4;
}

.hero-spacer {
  height: 340rpx;
}

.guest-highlight,
.brand-modal {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  background: linear-gradient(135deg, rgba(66,54,47,0.80), rgba(34,28,24,0.84));
  border: 1rpx solid rgba(197,154,116,0.28);
  box-shadow:
    0 24rpx 64rpx rgba(0,0,0,0.48),
    inset 0 1rpx 0 rgba(255,255,255,0.14);
}

.guest-highlight::before,
.brand-modal::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.10), transparent 18%, transparent 76%, rgba(216,166,120,0.05)),
    linear-gradient(90deg, rgba(255,255,255,0.018), transparent 30%, rgba(255,255,255,0.014) 52%, transparent 74%);
  pointer-events: none;
}

.guest-highlight {
  padding: 32rpx 28rpx 34rpx;
  margin-top: 8rpx;
}

.card-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(216,181,134,0.16);
}

.card-badge-icon {
  color: #f0c67e;
  font-size: 20rpx;
}

.card-badge-text {
  color: #e7c788;
  font-size: 24rpx;
  font-weight: 600;
}

.card-heading {
  position: relative;
  margin-top: 28rpx;
}

.card-title {
  display: block;
  padding-right: 0;
  max-width: 86%;
  font-size: 46rpx;
  line-height: 1.24;
  color: #fff3df;
  font-weight: 500;
  letter-spacing: 1rpx;
  font-family: "Songti SC", "STSong", "Noto Serif SC", serif;
}

.card-script {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  font-size: 24rpx;
  color: #dc8f96;
  font-style: italic;
  font-family: "Times New Roman", serif;
  transform: rotate(-3deg);
}

.card-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.84;
  color: rgba(247,239,230,0.70);
}

.scan-context {
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.03);
  border: 1rpx solid rgba(216,181,134,0.10);
}

.scan-context-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0;
}

.scan-label {
  font-size: 22rpx;
  color: rgba(247,239,230,0.48);
}

.scan-value {
  font-size: 23rpx;
  color: #f9f2ea;
  text-align: right;
}

.benefit-steps {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.benefit-step {
  flex: 1;
  min-height: 160rpx;
  padding: 18rpx 10rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.018);
  border: 1rpx solid rgba(216,181,134,0.10);
  text-align: center;
  box-sizing: border-box;
}

.benefit-step-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(216,181,134,0.34);
  color: #e7c788;
  font-size: 30rpx;
  font-weight: 600;
  font-family: "Songti SC", "STSong", serif;
}

.benefit-step-title {
  display: block;
  font-size: 26rpx;
  color: #f6ece0;
  font-weight: 520;
}

.benefit-step-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(247,239,230,0.48);
}

.hero-cta,
.mini-cta {
  width: 76%;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 24rpx;
  margin-left: auto;
  margin-right: auto;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, #e89590, #e8b1a5);
  color: #fff9f3;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 16rpx 34rpx rgba(232,149,144,0.28);
}

.hero-cta::after,
.mini-cta::after {
  border: none;
}

.trust-copy {
  margin-top: 20rpx;
  text-align: center;
}

.trust-line {
  display: inline-block;
  width: 40rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8d92, #f8d0c4);
}

.trust-text {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(247,239,230,0.66);
}

.trust-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(247,239,230,0.28);
}

.member-links {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin: 0 4rpx 18rpx;
}

.section-title {
  font-size: 32rpx;
  color: #fff1e2;
  font-weight: 600;
}

.section-script {
  font-size: 22rpx;
  color: #da8f97;
  font-style: italic;
}

.member-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 102rpx;
  padding: 0 26rpx;
  border-radius: 28rpx;
  background: rgba(24,18,17,0.66);
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.24);
  box-sizing: border-box;
}

.member-card--hover {
  transform: scale(0.99);
}

.member-card-icon {
  width: 74rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 50%;
  text-align: center;
  background: linear-gradient(135deg, #ed8893, #e8b0a3);
  color: #fffaf5;
  font-size: 30rpx;
  font-weight: 600;
}

.member-card-copy {
  flex: 1;
  min-width: 0;
}

.member-card-title {
  display: block;
  font-size: 26rpx;
  color: #fff4e8;
  font-weight: 600;
}

.member-card-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  color: rgba(247,239,230,0.52);
}

.member-card-arrow {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255,255,255,0.10);
  text-align: center;
  color: rgba(247,239,230,0.76);
  font-size: 36rpx;
}

.reauth-wrap {
  padding: 0 34rpx 26rpx;
}

.modal {
  position: fixed;
  inset: 0;
  z-index: 999;
}

.modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
}

.brand-modal {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 48%;
  transform: translateY(-50%);
  min-height: 720rpx;
}

.modal-bg,
.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.modal-bg {
  width: 100%;
  height: 100%;
  display: block;
  filter: saturate(1.08) brightness(1.04);
}

.modal-mask {
  background: linear-gradient(180deg, rgba(12,9,8,0.28), rgba(12,9,8,0.82));
}

.modal-content {
  position: relative;
  z-index: 1;
  padding: 34rpx;
}

.modal-cta {
  margin-top: 30rpx;
}

.modal-trust {
  margin-top: 24rpx;
}

.legacy {
  position: fixed;
  inset: 0;
  background: linear-gradient(160deg, #1a1412, #0d0d0d);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.legacy-inner {
  text-align: center;
  padding: 48rpx;
}

.legacy-title {
  color: #d4b87a;
  font-size: 52rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.legacy-sub {
  color: #a89b8c;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.legacy-points {
  color: #d4b87a;
  font-size: 76rpx;
  font-weight: 900;
}

.icp-footer {
  padding: 0 32rpx 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: rgba(247,239,230,0.24);
}

.voucher-toast {
  position: fixed;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(212,184,122,0.95);
  color: #0d0d0d;
  padding: 20rpx 36rpx;
  border-radius: 16rpx;
  z-index: 9000;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.voucher-toast-text {
  font-size: 28rpx;
  font-weight: 600;
}
.voucher-toast-sub {
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 4rpx;
}
