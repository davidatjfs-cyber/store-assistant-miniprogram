/* 扫码落地页 + 授权弹窗（与导航栏 #FF6A00 同系） */
.page {
  min-height: 100%;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff8f2 0%, #f8f5f2 45%, #f0ebe4 100%);
  padding: 32rpx 28rpx 48rpx;
}

.landing {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.landing-hero {
  text-align: center;
  padding: 48rpx 24rpx 40rpx;
}

.hero-mark {
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff8533, #ff6a00);
  color: #fff;
  font-size: 52rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 32rpx rgba(255, 106, 0, 0.35);
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #666;
  letter-spacing: 2rpx;
}

.landing-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 106, 0, 0.12);
}

.landing-card--warn {
  border-color: rgba(255, 152, 0, 0.35);
  background: #fffaf5;
}

.card-head-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.card-head-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
}

.card-meta {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #f0ebe4;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.meta-label {
  font-size: 26rpx;
  color: #888;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
  word-break: break-all;
}

.warn-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #c65a00;
  margin-bottom: 12rpx;
}

.warn-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
}

.reauth-wrap {
  margin-top: 40rpx;
  text-align: center;
  padding: 0 8rpx;
}

.reauth-hint {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.btn-outline {
  background: #fff;
  color: #ff6a00;
  border: 2rpx solid #ff6a00;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  height: 88rpx;
  font-weight: 500;
}

.btn-outline::after {
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
}

.modal-panel {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 86%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.12);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.modal-badge {
  align-self: center;
  display: inline-block;
  font-size: 22rpx;
  color: #ff6a00;
  background: rgba(255, 106, 0, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 20rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #555;
  line-height: 1.65;
  text-align: justify;
  margin-bottom: 36rpx;
}

.modal-btn {
  background: linear-gradient(145deg, #ff8533, #ff6a00);
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  height: 96rpx;
  border: none;
  box-shadow: 0 12rpx 28rpx rgba(255, 106, 0, 0.35);
}

.modal-btn::after {
  border: none;
}

.modal-foot {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #aaa;
  text-align: center;
  line-height: 1.4;
}

.legacy {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #ff8533, #ff6a00);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.legacy-inner {
  text-align: center;
  padding: 48rpx;
}

.legacy-title {
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.legacy-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.legacy-points {
  color: #fff;
  font-size: 72rpx;
  font-weight: 700;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.landing-links {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.link-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 999rpx;
  background: #ff6a00;
  color: #fff;
  font-size: 28rpx;
}

.link-btn--outline {
  background: #fff;
  color: #ff6a00;
  border: 2rpx solid #ff6a00;
}

/* 角色入口：2 列大按钮 */
.quick-area {
  margin-top: 40rpx;
  width: 100%;
}

.quick-sec-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #888;
  margin: 28rpx 0 20rpx;
  letter-spacing: 2rpx;
}

.quick-sec-title:first-child {
  margin-top: 8rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
  padding: 28rpx 16rpx;
  box-sizing: border-box;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 106, 0, 0.15);
  box-shadow: 0 10rpx 36rpx rgba(0, 0, 0, 0.06);
  text-decoration: none;
}

.quick-tile--hover {
  opacity: 0.92;
  transform: scale(0.98);
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ff8533, #ff6a00);
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 106, 0, 0.35);
}

.quick-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 10rpx;
}

.quick-sub {
  font-size: 22rpx;
  color: #888;
  text-align: center;
  line-height: 1.4;
}
