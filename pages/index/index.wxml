<view class="page guest-page">
  <view class="hero-bg-shell">
    <image class="page-bg" src="../../assets/home-hero-bg-toplit.jpg" mode="aspectFill"></image>
  </view>
  <view class="page-mask"></view>
  <view class="page-vignette"></view>

  <view class="page-shell" wx:if="{{pageReady}}">
    <view class="brand-head">
      <text class="brand-title">年年有喜</text>
      <view class="brand-status" wx:if="{{isFromScan}}">
        <text class="brand-status-dot"></text>
        <text class="brand-status-text">已连接</text>
      </view>
    </view>

    <view class="hero-spacer"></view>

    <view class="guest-highlight">
      <view class="card-badge">
        <text class="card-badge-icon">✦</text>
        <text class="card-badge-text">会员礼遇</text>
      </view>

      <view class="card-heading">
        <text class="card-title">{{storeConfig.welcomeTitle}}</text>
        <text class="card-script">join us</text>
      </view>

      <text class="card-desc">授权手机号入会，即可扫码点餐并享受专属优惠。</text>

      <view class="scan-context" wx:if="{{isFromScan && scanParams}}">
        <view class="scan-context-row">
          <text class="scan-label">门店</text>
          <text class="scan-value">{{scanParams.store_display_name || storeConfig.name}}</text>
        </view>
        <view class="scan-context-row">
          <text class="scan-label">桌台编号</text>
          <text class="scan-value">{{scanParams.table_id || '—'}}</text>
        </view>
      </view>

      <view class="benefit-steps">
        <view class="benefit-step">
          <view class="benefit-step-icon">惠</view>
          <text class="benefit-step-title">门店活动</text>
          <text class="benefit-step-sub">专属礼遇</text>
        </view>
        <view class="benefit-step">
          <view class="benefit-step-icon">券</view>
          <text class="benefit-step-title">我的优惠</text>
          <text class="benefit-step-sub">一键领取</text>
        </view>
      </view>

      <button
        wx:if="{{!hasAuthorizedMember}}"
        class="hero-cta"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >
        {{storeConfig.ctaText}}
      </button>
      <button
        wx:else
        class="hero-cta"
        bindtap="navigateToKeruYun"
      >
        去点餐
      </button>

      <view class="trust-copy">
        <text class="trust-line"></text>
        <text class="trust-text">{{storeConfig.trustText}}</text>
        <text class="trust-sub">信息安全保障中，请放心授权</text>
      </view>
    </view>

    <view class="member-links" wx:if="{{roleLoaded && entrySections.length}}">
      <view class="section-head">
        <text class="section-title">今晚礼遇</text>
        <text class="section-script">for your table</text>
      </view>
      <view class="member-grid">
        <block wx:for="{{entrySections}}" wx:for-item="sec" wx:key="title">
          <block wx:for="{{sec.items}}" wx:for-item="tile" wx:key="key">
            <navigator url="{{tile.url}}" class="member-card" hover-class="member-card--hover">
              <view class="member-card-icon">{{tile.icon}}</view>
              <view class="member-card-copy">
                <text class="member-card-title">{{tile.title}}</text>
                <text class="member-card-sub">{{tile.sub}}</text>
              </view>
              <text class="member-card-arrow">›</text>
            </navigator>
          </block>
        </block>
      </view>
    </view>
  </view>

  <!-- 券可用提醒 -->
  <view class="voucher-toast" wx:if="{{showVoucherTip && availableVoucherCount > 0}}">
    <text class="voucher-toast-text">您有 {{availableVoucherCount}} 张可用优惠券</text>
    <text class="voucher-toast-sub">点餐前可在「我的优惠券」查看</text>
  </view>

  <!-- 授权弹窗 -->
  <view wx:if="{{showAuthModal}}" class="modal">
    <view class="modal-backdrop" bindtap="onModalBackdropTap"></view>
    <view class="brand-modal">
      <image class="modal-bg" src="../../assets/home-hero-bg-toplit.jpg" mode="widthFix"></image>
      <view class="modal-mask"></view>

      <view class="modal-content">
        <view class="card-badge">
          <text class="card-badge-icon">✦</text>
          <text class="card-badge-text">会员礼遇</text>
        </view>

        <view class="card-heading">
          <text class="card-title">{{storeConfig.welcomeTitle}}</text>
          <text class="card-script">join us</text>
        </view>

        <text class="card-desc">授权手机号入会，即可扫码点餐并享受专属优惠。</text>

        <view class="benefit-steps">
          <view class="benefit-step">
            <view class="benefit-step-icon">惠</view>
            <text class="benefit-step-title">门店活动</text>
            <text class="benefit-step-sub">专属礼遇</text>
          </view>
          <view class="benefit-step">
            <view class="benefit-step-icon">券</view>
            <text class="benefit-step-title">我的优惠</text>
            <text class="benefit-step-sub">一键领取</text>
          </view>
        </view>

        <button class="hero-cta modal-cta" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">扫码点餐</button>

        <view class="trust-copy modal-trust">
          <text class="trust-line"></text>
          <text class="trust-text">{{storeConfig.trustText}}</text>
          <text class="trust-sub">信息安全保障中，请放心授权</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 老会员提示 -->
  <view wx:if="{{showLegacyMemberTip}}" class="legacy">
    <view class="legacy-inner">
      <view class="legacy-title">欢迎回来</view>
      <view class="legacy-sub">老会员积分已为您同步到账</view>
      <view class="legacy-points">+{{legacyMemberPoints}} 积分</view>
    </view>
  </view>

  <view class="icp-footer">沪ICP备2025128139号-2X</view>
</view>
