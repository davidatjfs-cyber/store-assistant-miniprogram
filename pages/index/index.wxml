<view class="page">
  <view class="landing" wx:if="{{pageReady}}">
    <view class="ambient ambient-a"></view>
    <view class="ambient ambient-b"></view>
    <view class="ambient ambient-c"></view>
    <view class="ambient ambient-d"></view>

    <!-- Hero -->
    <view class="hero-section">
      <view class="hero-shell">
        <view class="hero-copy">
          <view class="hero-kicker">PRIVATE DINING BENEFITS</view>
          <text class="hero-title">年年有喜</text>
          <text class="hero-subtitle">入会先看礼遇，点餐之前把今晚能用的优惠先选好。</text>
        </view>
        <view class="hero-orb">
          <view class="hero-orb-core">喜</view>
        </view>
      </view>
    </view>

    <!-- 欢迎卡片 -->
    <view class="arrival-card" wx:if="{{isFromScan}}">
      <view class="arrival-top">
        <view>
          <text class="arrival-label">今日到店</text>
          <text class="card-title">到店礼遇，先收进券包</text>
        </view>
        <view class="hero-mark">喜</view>
      </view>
      <text class="card-desc">完成授权后，今日可领的会员券与活动礼遇会先同步到券包，点餐前看一眼，更容易选到最划算的用法。</text>
      <view class="card-meta" wx:if="{{scanParams}}">
        <view class="meta-row">
          <text class="meta-label">门店</text>
          <text class="meta-value">{{scanParams.store_display_name || scanParams.store_id || '—'}}</text>
        </view>
        <view class="meta-row">
          <text class="meta-label">桌台编号</text>
          <text class="meta-value">{{scanParams.table_id || '—'}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-area" wx:if="{{roleLoaded && entrySections.length}}">
      <block wx:for="{{entrySections}}" wx:for-item="sec" wx:key="title">
        <view class="section-head">
          <text class="quick-sec-title">{{sec.title}}</text>
          <text class="section-glow"></text>
        </view>
        <view class="quick-grid">
          <navigator
            wx:for="{{sec.items}}"
            wx:for-item="tile"
            wx:key="key"
            url="{{tile.url}}"
            class="glass-tile"
            hover-class="glass-tile--hover"
          >
            <view class="quick-icon">{{tile.icon}}</view>
            <text class="quick-title">{{tile.title}}</text>
            <text class="quick-sub">{{tile.sub}}</text>
          </navigator>
        </view>
      </block>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="reauth-wrap" wx:if="{{!showAuthModal && !showLegacyMemberTip && pageReady}}">
    <button wx:if="{{!hasAuthorizedMember}}" class="btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">加入企微扫码点餐</button>
    <button wx:else class="btn-primary" bindtap="associateAndOrder">加企微扫码点餐</button>
  </view>

  <!-- 入会+企微+点餐 弹窗 -->
  <view wx:if="{{showAuthModal}}" class="modal">
    <view class="modal-backdrop"></view>
    <view class="glass-modal">
      <view class="modal-badge">会员礼遇</view>
      <view class="modal-title">加入企微，扫码点餐</view>
      <view class="modal-desc">授权手机号入会，自动关联企业微信领券，然后跳转点餐页面。</view>
      <view class="benefit-preview">
        <view class="benefit-mini"><text class="benefit-num">1</text><text>入会领券</text></view>
        <view class="benefit-mini"><text class="benefit-num">企</text><text>企微关联</text></view>
        <view class="benefit-mini"><text class="benefit-num">桌</text><text>扫码点餐</text></view>
      </view>
      <button class="btn-primary" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">加入企微扫码点餐</button>
      <view class="modal-foot">授权手机号仅用于会员识别与企微发券</view>
    </view>
  </view>

  <!-- 老会员提示 -->
  <view wx:if="{{showLegacyMemberTip}}" class="legacy">
    <view class="legacy-inner">
      <view class="legacy-title">欢迎回来</view>
      <view class="legacy-sub">老会员积分已为您同步到账</view>
      <view class="legacy-points">+{{legacyMemberPoints}} 积分</view>
    </view>
  </view>

  <view class="icp-footer">沪ICP备2025128139号-2X</view>
</view>
