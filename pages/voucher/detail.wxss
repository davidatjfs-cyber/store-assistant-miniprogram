page { background: #120f0d; color: #f4eadf; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 14% 0%, rgba(201,169,110,0.12), transparent 28%),
    radial-gradient(circle at 84% 12%, rgba(164,98,74,0.08), transparent 28%),
    linear-gradient(180deg, #100c0a 0%, #17110f 34%, #120f0d 100%);
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; filter: blur(18rpx); }
.ambient-a { width: 280rpx; height: 280rpx; right: -90rpx; top: 80rpx; background: radial-gradient(circle, rgba(255,227,184,0.18), rgba(201,169,110,0.10) 34%, transparent 72%); }
.ambient-b { width: 320rpx; height: 320rpx; left: -130rpx; bottom: 120rpx; background: radial-gradient(circle, rgba(148,93,67,0.16), transparent 72%); }

.hero-card,
.qr-panel,
.used-panel,
.miss-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  border-radius: 34rpx;
  padding: 34rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, rgba(57,44,36,0.96), rgba(26,20,17,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.40), inset 0 1rpx 0 rgba(255,255,255,0.12);
}
.hero-card::before,
.qr-panel::before,
.used-panel::before,
.miss-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255,255,255,0.10), transparent 28%, transparent 72%, rgba(217,138,131,0.04));
}

.hero-copy,
.hero-seal,
.status-panel,
.panel-top,
.qr-frame,
.used-title,
.used-desc,
.used-action,
.miss-title,
.miss-desc { position: relative; z-index: 1; }

.hero-copy { padding-right: 130rpx; }
.hero-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 5rpx; font-weight: 700; margin-bottom: 16rpx; }
.hero-title { display: block; font-size: 52rpx; line-height: 1.08; color: #fff2dc; font-weight: 700; }
.hero-rule { display: block; margin-top: 16rpx; font-size: 26rpx; color: rgba(243,234,223,0.70); line-height: 1.62; }

.hero-seal {
  position: absolute;
  right: 30rpx;
  top: 28rpx;
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  text-align: center;
  background: linear-gradient(135deg, #ead2a1, #cfa668);
  color: #2b1f18;
  font-size: 40rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 24rpx rgba(207,166,104,0.20);
}

.status-panel {
  margin-top: 34rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(227,196,160,0.12);
}
.status-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  align-items: flex-start;
}
.status-label { font-size: 24rpx; color: rgba(243,234,223,0.52); }
.status-value { font-size: 28rpx; color: #f7ecdd; font-weight: 600; text-align: right; }
.status-code {
  max-width: 60%;
  font-size: 24rpx;
  color: rgba(243,234,223,0.72);
  text-align: right;
  word-break: break-all;
}

.panel-top { text-align: center; }
.panel-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 5rpx; font-weight: 700; margin-bottom: 16rpx; }
.panel-title { display: block; font-size: 40rpx; color: #fff2dc; font-weight: 700; }
.panel-desc { display: block; margin-top: 14rpx; font-size: 25rpx; color: rgba(243,234,223,0.66); line-height: 1.6; }

.qr-frame {
  width: 470rpx;
  height: 470rpx;
  margin: 30rpx auto 0;
  padding: 22rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(244,219,185,0.12));
  border: 1rpx solid rgba(255,255,255,0.12);
}
.qr-canvas {
  display: block;
  width: 426rpx !important;
  height: 426rpx !important;
  margin: 0 auto;
  background: #ffffff;
  border-radius: 18rpx;
}

.used-panel,
.miss-card { text-align: center; padding-top: 56rpx; padding-bottom: 56rpx; }
.used-title,
.miss-title { display: block; font-size: 38rpx; color: #fff2dc; font-weight: 700; }
.used-desc,
.miss-desc { display: block; margin-top: 16rpx; font-size: 26rpx; color: rgba(243,234,223,0.64); line-height: 1.62; }
.used-action {
  display: inline-block;
  margin-top: 34rpx;
  min-width: 220rpx;
  padding: 0 32rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(135deg, #d98a83, #e6ac9f);
  color: #fff7ef;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 30rpx rgba(217,138,131,0.24);
}

.page.miss {
  display: flex;
  align-items: center;
  justify-content: center;
}
.miss-card { width: 100%; }
