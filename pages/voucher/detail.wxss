/* 券详情 - 液态玻璃 (高亮银色) */
page { background: #0a0a0a; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 32rpx;
}

.page.miss { display: flex; align-items: center; justify-content: center; color: #C0C0C0; font-size: 28rpx; }

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx; padding: 36rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
}

.title {
  display: block; font-size: 36rpx; font-weight: 700; color: #ffffff;
  text-shadow: 0 0 12rpx rgba(255,255,255,0.5);
}

.rule { display: block; margin-top: 16rpx; font-size: 26rpx; color: #C0C0C0; line-height: 1.5; }

.status-row {
  display: flex; justify-content: space-between; margin-top: 24rpx;
  padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,0.08); font-size: 28rpx;
}

.label { color: #B0B0B0; }
.val { color: #E8E8E8; font-weight: 500; text-shadow: 0 0 8rpx rgba(255,255,255,0.3); }

.qr-panel { text-align: center; }
.qr-title { display: block; font-size: 30rpx; font-weight: 600; color: #ffffff; text-shadow: 0 0 10rpx rgba(255,255,255,0.4); }
.qr-tip { display: block; margin-top: 8rpx; font-size: 24rpx; color: #B0B0B0; }

.qr-canvas {
  display: block; margin: 28rpx auto 0; width: 400rpx !important; height: 400rpx !important;
  background: #ffffff; border-radius: 16rpx;
}

.qr-code-text { display: block; margin-top: 20rpx; font-size: 22rpx; color: #B0B0B0; word-break: break-all; }

.used-tip { text-align: center; font-size: 28rpx; color: #B0B0B0; }
