page { background: #fbf4e8; }

.page {
  min-height: 100vh;
  padding: 34rpx 32rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 4%, rgba(141,35,45,0.10), transparent 30%),
    radial-gradient(circle at 88% 16%, rgba(101,122,76,0.12), transparent 34%),
    linear-gradient(180deg, #fff8ed, #f7ecdc 62%);
}

.wallet-hero { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; padding: 46rpx 4rpx 32rpx; }
.wallet-kicker { display: block; font-size: 20rpx; color: #8d232d; letter-spacing: 4rpx; font-weight: 900; margin-bottom: 14rpx; }
.wallet-title { display: block; font-size: 56rpx; line-height: 1.04; color: #261c16; font-weight: 900; }
.top-hint { display: block; margin-top: 16rpx; font-size: 25rpx; color: rgba(38,28,22,0.58); line-height: 1.5; }
.btn-glass { flex: 0 0 auto; margin-top: 6rpx; background: #fffaf2 !important; color: #261c16 !important; border: 1rpx solid rgba(38,28,22,0.12) !important; border-radius: 999rpx !important; font-size: 24rpx !important; }
.btn-glass::after { border: none; }

.state { text-align: center; padding: 150rpx 32rpx; color: rgba(38,28,22,0.62); font-size: 30rpx; }
.state.empty .sub { display: block; margin-top: 16rpx; font-size: 25rpx; color: rgba(38,28,22,0.44); }
.list { display: flex; flex-direction: column; gap: 22rpx; }

.voucher-item {
  position: relative; overflow: hidden; padding: 34rpx; border-radius: 34rpx;
  background: #fffaf2;
  color: #261c16;
  border: 1rpx solid rgba(38,28,22,0.10);
  box-shadow: 0 18rpx 48rpx rgba(70,45,28,0.10);
}
.voucher-item::before,
.voucher-item::after { content: ''; position: absolute; top: 50%; width: 42rpx; height: 42rpx; margin-top: -21rpx; border-radius: 50%; background: #f7ecdc; border: 1rpx solid rgba(38,28,22,0.08); }
.voucher-item::before { left: -22rpx; }
.voucher-item::after { right: -22rpx; }
.voucher-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.voucher-label { display: block; font-size: 21rpx; font-weight: 900; letter-spacing: 3rpx; color: #8d232d; margin-bottom: 10rpx; }
.voucher-name { display: block; font-size: 40rpx; line-height: 1.18; font-weight: 900; color: #261c16; }
.badge { flex: 0 0 auto; font-size: 22rpx; padding: 8rpx 16rpx; border-radius: 999rpx; white-space: nowrap; font-weight: 900; }
.badge--unused { background: rgba(101,122,76,0.12); color: #657a4c; }
.badge--used,
.badge--expired { background: rgba(38,28,22,0.07); color: rgba(38,28,22,0.44); }
.voucher-meta { margin-top: 42rpx; padding-top: 24rpx; border-top: 2rpx dashed rgba(38,28,22,0.16); }
.meta { font-size: 25rpx; color: rgba(38,28,22,0.58); font-weight: 700; }
.voucher-foot { margin-top: 22rpx; display: flex; justify-content: space-between; align-items: center; }
.link { font-size: 28rpx; color: #8d232d; font-weight: 900; }
.arrow { width: 48rpx; height: 48rpx; line-height: 44rpx; text-align: center; border-radius: 50%; border: 2rpx solid rgba(141,35,45,0.18); color: #8d232d; font-size: 38rpx; font-weight: 900; }
