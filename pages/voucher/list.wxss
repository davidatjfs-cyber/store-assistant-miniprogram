page { background: #120f0d; color: #f4eadf; }

.page {
  min-height: 100vh;
  padding: 34rpx 28rpx 56rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 0%, rgba(201,169,110,0.12), transparent 26%),
    radial-gradient(circle at 88% 10%, rgba(164,98,74,0.08), transparent 28%),
    linear-gradient(180deg, #100c0a 0%, #181210 32%, #120f0d 100%);
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; filter: blur(18rpx); }
.ambient-a { width: 280rpx; height: 280rpx; right: -90rpx; top: 70rpx; background: radial-gradient(circle, rgba(255,227,184,0.18), rgba(201,169,110,0.10) 34%, transparent 72%); }
.ambient-b { width: 320rpx; height: 320rpx; left: -130rpx; bottom: 90rpx; background: radial-gradient(circle, rgba(148,93,67,0.16), transparent 72%); }

.wallet-hero {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 36rpx 4rpx 28rpx;
}
.wallet-copy { flex: 1; }
.wallet-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 6rpx; font-weight: 700; margin-bottom: 14rpx; }
.wallet-title { display: block; font-size: 60rpx; line-height: 1.02; color: #fff2dc; font-weight: 700; }
.wallet-desc { display: block; margin-top: 18rpx; font-size: 26rpx; color: rgba(243,234,223,0.68); line-height: 1.62; }
.btn-glass {
  flex: 0 0 auto;
  margin-top: 10rpx;
  padding: 0 28rpx !important;
  height: 70rpx !important;
  line-height: 70rpx !important;
  background: rgba(255,255,255,0.06) !important;
  color: #efd39a !important;
  border: 1rpx solid rgba(239,211,154,0.20) !important;
  border-radius: 999rpx !important;
  font-size: 24rpx !important;
}
.btn-glass::after { border: none; }

.state {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 160rpx 32rpx;
  color: rgba(243,234,223,0.52);
  font-size: 30rpx;
}

.empty-shell { position: relative; z-index: 1; padding-top: 80rpx; }
.empty-card {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  padding: 52rpx 36rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(57,44,36,0.94), rgba(28,22,19,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 22rpx 56rpx rgba(0,0,0,0.40), inset 0 1rpx 0 rgba(255,255,255,0.12);
}
.empty-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 80% 20%, rgba(255,226,176,0.12), transparent 16%),
    linear-gradient(180deg, rgba(255,255,255,0.08), transparent 34%, transparent 76%, rgba(227,196,160,0.04));
}
.empty-kicker,
.empty-title,
.empty-desc,
.empty-action { position: relative; z-index: 1; }
.empty-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 6rpx; font-weight: 700; margin-bottom: 18rpx; }
.empty-title { display: block; font-size: 38rpx; color: #fff1dc; font-weight: 700; }
.empty-desc { display: block; margin-top: 18rpx; font-size: 26rpx; color: rgba(243,234,223,0.66); line-height: 1.64; }
.empty-action {
  display: inline-block;
  min-width: 220rpx;
  margin-top: 34rpx;
  padding: 0 32rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  text-align: center;
  background: linear-gradient(135deg, #d98a83, #e6ac9f);
  color: #fff7ef;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 32rpx rgba(217,138,131,0.26);
}

.list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.voucher-item {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 30rpx 30rpx 26rpx;
  background: linear-gradient(135deg, rgba(82,62,50,0.96), rgba(36,28,24,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 22rpx 54rpx rgba(0,0,0,0.34), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.voucher-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255,255,255,0.10), transparent 28%, transparent 72%, rgba(217,138,131,0.04));
}
.voucher-halo {
  position: absolute;
  top: -12rpx;
  left: 44rpx;
  width: 170rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0.02));
  transform: rotate(-10deg);
  filter: blur(2rpx);
}

.voucher-top,
.voucher-middle,
.voucher-foot { position: relative; z-index: 1; }
.voucher-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.voucher-copy { flex: 1; min-width: 0; }
.voucher-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 5rpx; font-weight: 700; margin-bottom: 12rpx; }
.voucher-name { display: block; font-size: 38rpx; line-height: 1.18; color: #fff1dc; font-weight: 700; }

.badge {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.badge--unused { background: linear-gradient(135deg, #e4c18c, #f2d9a9); color: #35261c; }
.badge--active { background: linear-gradient(135deg, #e4c18c, #f2d9a9); color: #35261c; }
.badge--used,
.badge--expired { background: rgba(255,255,255,0.06); color: rgba(243,234,223,0.56); }

.voucher-middle {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 28rpx;
  padding-top: 22rpx;
  border-top: 1rpx dashed rgba(227,196,160,0.18);
}
.voucher-meta { display: flex; flex-direction: column; gap: 10rpx; }
.meta-label { font-size: 22rpx; color: rgba(243,234,223,0.52); }
.meta-value { font-size: 30rpx; color: #f7ecdd; font-weight: 600; }
.voucher-seal {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 50%;
  text-align: center;
  background: linear-gradient(135deg, #ead2a1, #cfa668);
  color: #2b1f18;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 26rpx rgba(207,166,104,0.22);
}

.voucher-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 20rpx;
}
.foot-text { font-size: 28rpx; color: #f1cbbd; font-weight: 600; }
.foot-arrow {
  width: 54rpx;
  height: 54rpx;
  line-height: 50rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(241,203,189,0.28);
  text-align: center;
  color: #f1cbbd;
  font-size: 40rpx;
}
