/* 券列表 - 液态玻璃 (高亮银色) */
page { background: #0a0a0a; }

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0a0a0a 0%, #1a1a2e 30%, #16213e 60%, #0a0a0a 100%);
  padding: 32rpx;
}

.top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }

.top-hint {
  flex: 1; font-size: 24rpx; color: #B0B0B0; padding-right: 16rpx;
  text-shadow: 0 0 6rpx rgba(255,255,255,0.2);
}

.btn-glass {
  background: rgba(255,255,255,0.1) !important; color: #ffffff !important;
  border: 1rpx solid rgba(255,255,255,0.25) !important; border-radius: 999rpx !important; font-size: 24rpx !important;
}
.btn-glass::after { border: none; }

.state { text-align: center; padding: 120rpx 32rpx; color: #C0C0C0; font-size: 28rpx; }
.state.empty .sub { display: block; margin-top: 12rpx; font-size: 24rpx; color: #888888; }

.list { display: flex; flex-direction: column; gap: 20rpx; }

.glass-card {
  background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx; padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3), inset 0 1rpx 0 rgba(255,255,255,0.1);
}

.voucher-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }

.voucher-name {
  font-size: 32rpx; font-weight: 600; color: #ffffff; flex: 1;
  text-shadow: 0 0 10rpx rgba(255,255,255,0.4);
}

.badge { font-size: 22rpx; padding: 6rpx 14rpx; border-radius: 999rpx; white-space: nowrap; font-weight: 600; }
.badge--unused { background: linear-gradient(135deg, #ff6a00, #ff8533); color: #ffffff; }
.badge--used { background: rgba(255,255,255,0.15); color: #D0D0D0; }
.badge--expired { background: rgba(255,255,255,0.15); color: #D0D0D0; }

.voucher-meta { margin-top: 16rpx; }
.meta { font-size: 24rpx; color: #B0B0B0; }

.voucher-foot { margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.08); }
.link { font-size: 26rpx; color: #ff9a5c; }
