page { background: #0d0d0d; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 0%, rgba(201,169,110,0.08), transparent 30%),
    radial-gradient(circle at 82% 10%, rgba(160,120,60,0.06), transparent 34%),
    linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; }
.ambient-a { width: 300rpx; height: 300rpx; right: -90rpx; top: 50rpx; background: radial-gradient(circle, rgba(255,255,255,0.10), rgba(201,169,110,0.08) 34%, transparent 72%); filter: blur(16rpx); }
.ambient-b { width: 340rpx; height: 340rpx; left: -120rpx; bottom: 120rpx; background: radial-gradient(circle, rgba(120,160,255,0.06), transparent 74%); filter: blur(24rpx); }

.hero { padding: 20rpx 4rpx 30rpx; }
.hero-shell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 24rpx 24rpx 6rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0.07), rgba(201,169,110,0.04) 40%, rgba(120,160,255,0.04));
  border: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display: block; margin-bottom: 14rpx; font-size: 18rpx; color: #c9a96e; letter-spacing: 6rpx; font-weight: 800; }
.hero-title { display: block; font-size: 56rpx; line-height: 1.04; font-weight: 900; color: #eef2ff; text-shadow: 0 8rpx 30rpx rgba(157,187,255,0.10); }
.hero-desc { display: block; margin-top: 18rpx; font-size: 26rpx; line-height: 1.55; color: #99a8c8; }
.hero-lens {
  position: relative;
  width: 138rpx;
  height: 138rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.28), rgba(255,255,255,0.10) 20%, rgba(201,169,110,0.18) 48%, rgba(120,160,255,0.08) 72%, transparent 100%);
  border: 1rpx solid rgba(255,255,255,0.14);
  box-shadow: inset 0 2rpx 10rpx rgba(255,255,255,0.12), 0 18rpx 40rpx rgba(0,0,0,0.28);
}
.hero-lens::before { content: ''; position: absolute; top: 18rpx; left: 18rpx; width: 56rpx; height: 28rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.04)); transform: rotate(-20deg); }

.glass-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 36%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border-radius: 28rpx; padding: 36rpx; margin-bottom: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.4), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.glass-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: linear-gradient(180deg, rgba(255,255,255,0.18), transparent 30%, transparent 72%, rgba(120,160,255,0.05)); pointer-events: none; }

.arrivals-card { margin-bottom: 24rpx; }
.panel-shine { position: absolute; top: -18rpx; left: 42rpx; width: 180rpx; height: 64rpx; border-radius: 999rpx; background: linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0.02)); transform: rotate(-10deg); filter: blur(2rpx); }

.title {
  display: block; font-size: 36rpx; font-weight: 800; color: #eef2ff;
}

.desc { display: block; margin-top: 12rpx; font-size: 26rpx; color: #99a8c8; line-height: 1.5; margin-bottom: 24rpx; }

.arrival { margin-top: 24rpx; padding-top: 24rpx; border-top: 1rpx solid rgba(201,169,110,0.08); }
.arrival--first { margin-top: 12rpx; padding-top: 0; border-top: none; }
.arrival-head { margin-bottom: 8rpx; }
.arrival-name-row { display: flex; flex-wrap: wrap; align-items: center; gap: 14rpx; }

.arrival-name {
  font-size: 32rpx; font-weight: 800; color: #e8e0d4;
}

.level-tag { font-size: 22rpx; font-weight: 700; padding: 6rpx 16rpx; border-radius: 12rpx; letter-spacing: 1rpx; }
.level-tag--vip { color: #0d0d0d; background: linear-gradient(135deg, #c9a96e, #d4b87a); }
.level-tag--active,
.level-tag--regular { color: #d4b87a; background: rgba(201,169,110,0.08); border: 1rpx solid rgba(201,169,110,0.14); }
.level-tag--new { color: #8a7e72; background: rgba(232,224,212,0.06); border: 1rpx solid rgba(232,224,212,0.1); }
.level-tag--prospect { color: #94a3b8; background: rgba(148,163,184,0.10); border: 1rpx solid rgba(148,163,184,0.16); }
.level-tag--at_risk { color: #f0b35a; background: rgba(240,179,90,0.10); border: 1rpx solid rgba(240,179,90,0.16); }
.level-tag--dormant { color: #d97676; background: rgba(217,118,118,0.10); border: 1rpx solid rgba(217,118,118,0.16); }
.level-tag--churned { color: #b7aca1; background: rgba(183,172,161,0.10); border: 1rpx solid rgba(183,172,161,0.16); }

.arrival-line { display: block; font-size: 26rpx; color: #99a8c8; margin-top: 6rpx; }
.arrival-tags { margin-top: 12rpx; display: flex; flex-wrap: wrap; gap: 10rpx; }

.tag {
  font-size: 22rpx; color: #d4b87a; background: rgba(201,169,110,0.06);
  padding: 6rpx 14rpx; border-radius: 10rpx; border: 1rpx solid rgba(201,169,110,0.12);
}

.field { margin-top: 28rpx; margin-bottom: 24rpx; }
.field-label { display: block; font-size: 24rpx; color: #95a4c7; margin-bottom: 10rpx; }

.field-input {
  background: rgba(232,224,212,0.06); border: 1rpx solid rgba(201,169,110,0.14);
  border-radius: 16rpx; padding: 20rpx; font-size: 28rpx; color: #e8e0d4;
}
.field-input::placeholder { color: rgba(232,224,212,0.3); }

.btn-primary {
  margin-top: 12rpx; background: linear-gradient(135deg, #c9a96e, #d4b87a);
  color: #0d0d0d; border-radius: 999rpx; font-size: 30rpx; font-weight: 800;
  box-shadow: 0 12rpx 32rpx rgba(201,169,110,0.24);
}

.store { display: block; margin-top: 20rpx; font-size: 24rpx; color: #95a4c7; text-align: center; }

.result { text-align: center; }
.result-icon { width: 80rpx; height: 80rpx; line-height: 80rpx; border-radius: 50%; margin: 0 auto 16rpx; font-size: 44rpx; font-weight: 800; color: #0d0d0d; }
.result-icon.ok { background: linear-gradient(135deg, #c9a96e, #d4b87a); }
.result-icon.bad { background: linear-gradient(135deg, #8f4a39, #c27b5f); }
.result-msg { font-size: 30rpx; color: #e8e0d4; }

.redeemed-detail { margin-top: 24rpx; padding: 20rpx 24rpx; border-radius: 16rpx; background: rgba(143,74,57,0.16); border: 1rpx solid rgba(194,123,95,0.4); text-align: left; }
.redeemed-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.redeemed-key { font-size: 26rpx; color: #b8a98f; }
.redeemed-val { font-size: 28rpx; color: #f0e7d8; font-weight: 600; }
.redeemed-note { display: block; margin-top: 12rpx; font-size: 24rpx; color: #c27b5f; }

.regular-modal { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
.regular-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
.regular-card { position: relative; z-index: 1; width: 560rpx; padding: 48rpx 40rpx 40rpx; border-radius: 32rpx; text-align: center; background: linear-gradient(160deg, #241c16, #14110d); border: 1rpx solid rgba(212,184,122,0.4); box-shadow: 0 24rpx 64rpx rgba(0,0,0,0.5); }
.regular-kicker { display: block; font-size: 28rpx; color: #d4b87a; letter-spacing: 2rpx; }
.regular-name { display: block; margin-top: 20rpx; font-size: 48rpx; font-weight: 800; color: #f6ece0; }
.regular-line { display: block; margin-top: 12rpx; font-size: 28rpx; color: rgba(246,236,224,0.78); }
.regular-btn { margin-top: 32rpx; height: 80rpx; line-height: 80rpx; border-radius: 999rpx; border: none; background: linear-gradient(135deg, #c9a96e, #d4b87a); color: #1a1410; font-size: 30rpx; font-weight: 700; }
.regular-btn::after { border: none; }

.arrival-profile { margin-top: 14rpx; display: flex; align-items: center; justify-content: space-between; gap: 12rpx; }
.arrival-profile-tip { font-size: 24rpx; color: #95a4c7; }
.arrival-profile-tip--todo { color: #c27b5f; }
.arrival-profile-btn {
  font-size: 24rpx; color: #d4b87a; padding: 8rpx 22rpx; border-radius: 999rpx;
  border: 1rpx solid rgba(201,169,110,0.4); background: rgba(201,169,110,0.08);
}
.gender-row { display: flex; gap: 16rpx; }
.gender-opt {
  flex: 1; text-align: center; padding: 18rpx 0; font-size: 28rpx; color: #e8e0d4;
  border-radius: 16rpx; border: 1rpx solid rgba(201,169,110,0.14); background: rgba(232,224,212,0.06);
}
.gender-opt--on { color: #1a1410; background: linear-gradient(135deg, #c9a96e, #d4b87a); border-color: transparent; font-weight: 700; }

.redeem-item {
  margin-top: 16rpx; padding: 20rpx 24rpx; border-radius: 16rpx;
  background: rgba(232,224,212,0.05); border: 1rpx solid rgba(201,169,110,0.16);
}
.redeem-item-main { display: flex; justify-content: space-between; align-items: center; gap: 12rpx; }
.redeem-item-label { flex: 1; font-size: 28rpx; color: #f0e7d8; font-weight: 600; }
.redeem-item-time { font-size: 24rpx; color: #95a4c7; }
.redeem-item-code { display: block; margin-top: 8rpx; font-size: 24rpx; color: #d4b87a; }
