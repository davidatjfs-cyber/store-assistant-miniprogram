<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>
  <view class="hero">
    <view class="hero-shell">
      <view class="hero-copy">
        <text class="hero-kicker">STAFF VERIFY</text>
        <text class="hero-title">门店核销台</text>
        <text class="hero-desc">查看到店顾客画像，并在收银前快速完成验券。</text>
      </view>
      <view class="hero-lens"></view>
    </view>
  </view>

  <!-- 到店顾客 -->
  <view class="glass-card arrivals-card" wx:if="{{arrivalsLoaded && arrivals.length}}">
    <view class="panel-shine"></view>
    <text class="title">当前到店顾客</text>
    <text class="desc">最近到店记录（本门店）</text>
    <view class="arrival {{index === 0 ? 'arrival--first' : ''}}" wx:for="{{arrivals}}" wx:key="user_id">
      <view class="arrival-head">
        <view class="arrival-name-row">
          <text class="arrival-name">{{item.display_name}}{{item.level_suffix}}</text>
          <text class="level-tag level-tag--{{item.user_level || 'prospect'}}">{{item.user_level_label || '潜在新客'}}</text>
        </view>
      </view>
      <text class="arrival-line">来店：{{item.total_visits}}次</text>
      <text class="arrival-line">最近：{{item.recent_label}}</text>
      <text class="arrival-line" wx:if="{{item.favorite_dish}}">偏好：{{item.favorite_dish}}</text>
      <view class="arrival-tags" wx:if="{{item.tag_labels.length}}">
        <text class="tag" wx:for="{{item.tag_labels}}" wx:for-item="tg" wx:for-index="ti" wx:key="ti">{{tg}}</text>
      </view>
      <view class="arrival-profile">
        <text class="arrival-profile-tip" wx:if="{{item.title}}">称呼：{{item.title}}</text>
        <text class="arrival-profile-tip arrival-profile-tip--todo" wx:else>未完善姓名/性别</text>
        <text class="arrival-profile-btn" data-user-id="{{item.user_id}}" data-name="{{item.display_name}}" data-surname="{{item.surname}}" data-gender="{{item.gender}}" bindtap="openProfileEdit">{{item.title ? '修改' : '补全资料'}}</text>
      </view>
    </view>
  </view>

  <!-- 核销 -->
  <view class="glass-card">
    <view class="panel-shine"></view>
    <text class="title">门店核销</text>
    <text class="desc">扫描顾客券详情页展示的二维码</text>
    <view class="field">
      <text class="field-label">本单消费金额（元）</text>
      <input class="field-input" type="digit" placeholder="券模板设了最低消费时必填，按元填写" value="{{orderAmountYuan}}" bindinput="onAmountInput" />
    </view>
    <button class="btn-primary" type="primary" bindtap="onScan">扫一扫核销</button>
    <view class="field" style="margin-top:16rpx;">
      <text class="field-label">或输入券码核销（客人报短信里的 6 位码）</text>
      <input class="field-input" type="number" maxlength="6" placeholder="6 位券码" value="{{manualCode}}" bindinput="onCodeInput" />
    </view>
    <button class="btn-primary" type="default" bindtap="onVerifyByCode">凭码核销</button>
    <text class="store" wx:if="{{storeId}}">当前门店：{{storeId}}</text>
  </view>

  <!-- 结果 -->
  <view class="glass-card result" wx:if="{{lastMessage}}">
    <view class="result-icon {{lastOk ? 'ok' : 'bad'}}">{{lastOk ? '✓' : '!'}}</view>
    <text class="result-msg">{{lastMessage}}</text>
    <!-- 已核销券：常驻展示核销详情，避免店员看不清 -->
    <view class="redeemed-detail" wx:if="{{redeemedInfo}}">
      <view class="redeemed-row"><text class="redeemed-key">核销时间</text><text class="redeemed-val">{{redeemedInfo.time}}</text></view>
      <view class="redeemed-row" wx:if="{{redeemedInfo.shortCode}}"><text class="redeemed-key">券码</text><text class="redeemed-val">{{redeemedInfo.shortCode}}</text></view>
      <view class="redeemed-row" wx:if="{{redeemedInfo.valueYuan}}"><text class="redeemed-key">面额</text><text class="redeemed-val">{{redeemedInfo.valueYuan}} 元</text></view>
      <text class="redeemed-note">此券为一次性券，不可重复使用</text>
    </view>
  </view>

  <!-- 近期核销记录：常驻列表，店员可事后复查、对账 POS（点任意一条重看详情） -->
  <view class="glass-card" wx:if="{{redemptions.length}}">
    <view class="panel-shine"></view>
    <text class="title">近期核销记录</text>
    <text class="desc">本门店最近核销 · 点任意一条可重看「活动名+面额+券码」，对账 POS 用</text>
    <view class="redeem-item" wx:for="{{redemptions}}" wx:key="log_id" data-idx="{{index}}" bindtap="onTapRedemption">
      <view class="redeem-item-main">
        <text class="redeem-item-label">{{item.coupon_label}}</text>
        <text class="redeem-item-time">{{item.time_text}}</text>
      </view>
      <text class="redeem-item-code" wx:if="{{item.short_code}}">券码 {{item.short_code}}</text>
    </view>
  </view>

  <!-- 补全资料弹窗 -->
  <view class="regular-modal" wx:if="{{profileEditVisible}}">
    <view class="regular-backdrop" bindtap="closeProfileEdit"></view>
    <view class="regular-card">
      <text class="regular-kicker">完善顾客资料</text>
      <text class="regular-name">{{editName}}</text>
      <view class="field">
        <text class="field-label">姓（如「张」，复姓可填2字）</text>
        <input class="field-input" maxlength="-1" placeholder="请输入中文姓氏" value="{{editSurname}}" bindinput="onSurnameInput" />
      </view>
      <view class="field">
        <text class="field-label">性别</text>
        <view class="gender-row">
          <text class="gender-opt {{editGender === 'male' ? 'gender-opt--on' : ''}}" data-gender="male" bindtap="selectGender">先生</text>
          <text class="gender-opt {{editGender === 'female' ? 'gender-opt--on' : ''}}" data-gender="female" bindtap="selectGender">女士</text>
        </view>
      </view>
      <button class="regular-btn" loading="{{profileSaving}}" disabled="{{profileSaving}}" bindtap="saveProfile">保存</button>
      <text class="arrival-profile-tip" bindtap="closeProfileEdit" style="margin-top:12rpx;">取消</text>
    </view>
  </view>

  <!-- 熟客到店实时弹窗 -->
  <view class="regular-modal" wx:if="{{regularTipVisible}}">
    <!-- 背景层不再可点关闭，避免服务员忙碌时误触导致提醒一闪而过 -->
    <view class="regular-backdrop" catchtap="noop"></view>
    <view class="regular-card">
      <text class="regular-kicker">🔔 熟客到店</text>
      <text class="regular-name">{{regularTip.display_name}}</text>
      <text class="regular-line">累计到店 {{regularTip.total_visits}} 次</text>
      <text class="regular-line" wx:if="{{regularTip.favorite_dish}}">偏好：{{regularTip.favorite_dish}}</text>
      <button class="regular-btn" bindtap="closeRegularTip">知道了，已确认</button>
    </view>
  </view>
</view>
