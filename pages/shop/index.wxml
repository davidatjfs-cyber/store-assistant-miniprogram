<view class="page">
  <view class="ambient ambient-a"></view>
  <view class="ambient ambient-b"></view>

  <view class="hero-shell">
    <view class="hero-copy">
      <text class="hero-kicker">CURATED DINING PRIVILEGES</text>
      <text class="hero-title">甄选礼遇</text>
      <text class="hero-desc">点餐前先挑一张更适合今晚的礼遇，优惠会更从容。</text>
    </view>
    <view class="hero-orb">礼</view>
  </view>

  <view wx:if="{{loading}}" class="state">
    <text>礼遇加载中…</text>
  </view>

  <view wx:elif="{{!templates.length}}" class="empty-card">
    <text class="empty-kicker">COMING SOON</text>
    <text class="empty-title">今晚暂时没有可选礼遇</text>
    <text class="empty-desc">稍后回来看看，新的礼遇上架后会出现在这里。</text>
  </view>

  <view wx:else class="list">
    <view class="shop-item" wx:for="{{templates}}" wx:key="_id">
      <view class="item-top">
        <view class="item-badge">{{item.type === 'cash' ? '¥' : '折'}}</view>
        <view class="item-copy">
          <text class="item-kicker">{{item.benefitText}}</text>
          <text class="item-name">{{item.name}}</text>
          <text class="item-rule" wx:if="{{item.usage_rule}}">{{item.usage_rule}}</text>
        </view>
      </view>

      <view class="item-grid">
        <view class="info-cell">
          <text class="info-label">到手价</text>
          <text class="info-value info-price">¥{{item.priceYuan}}</text>
        </view>
        <view class="info-cell">
          <text class="info-label">使用期限</text>
          <text class="info-value">下单后{{item.valid_days}}天内可用</text>
        </view>
        <view class="info-cell info-cell--full">
          <text class="info-label">库存状态</text>
          <text class="info-value {{item.stock === 0 ? 'muted' : ''}}">{{item.stockText}}</text>
        </view>
      </view>

      <button class="buy-btn {{item.stock === 0 ? 'buy-btn--disabled' : ''}}"
              disabled="{{item.stock === 0}}"
              data-id="{{item._id}}"
              bindtap="onBuy">
        {{item.stock === 0 ? '暂时售罄' : item.price === 0 ? '直接领取' : '立即锁定'}}
      </button>
    </view>
  </view>
</view>
