page { background: #120f0d; color: #f4eadf; }

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  padding: 36rpx 28rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 14% 0%, rgba(201,169,110,0.12), transparent 28%),
    radial-gradient(circle at 86% 12%, rgba(164,98,74,0.08), transparent 30%),
    linear-gradient(180deg, #100c0a 0%, #17110f 34%, #120f0d 100%);
}

.ambient { position: absolute; border-radius: 999rpx; pointer-events: none; filter: blur(18rpx); }
.ambient-a { width: 280rpx; height: 280rpx; right: -90rpx; top: 70rpx; background: radial-gradient(circle, rgba(255,227,184,0.18), rgba(201,169,110,0.10) 34%, transparent 72%); }
.ambient-b { width: 320rpx; height: 320rpx; left: -130rpx; bottom: 90rpx; background: radial-gradient(circle, rgba(148,93,67,0.16), transparent 72%); }

.hero-shell {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(57,44,36,0.96), rgba(24,18,15,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.40), inset 0 1rpx 0 rgba(255,255,255,0.12);
}
.hero-shell::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255,255,255,0.10), transparent 28%, transparent 72%, rgba(217,138,131,0.04));
}
.hero-copy,
.hero-orb { position: relative; z-index: 1; }
.hero-copy { flex: 1; min-width: 0; }
.hero-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 6rpx; font-weight: 700; margin-bottom: 16rpx; }
.hero-title { display: block; font-size: 58rpx; line-height: 1.02; color: #fff2dc; font-weight: 700; }
.hero-desc { display: block; margin-top: 18rpx; font-size: 26rpx; color: rgba(243,234,223,0.68); line-height: 1.6; }
.hero-orb {
  flex: 0 0 auto;
  width: 128rpx;
  height: 128rpx;
  line-height: 128rpx;
  border-radius: 50%;
  text-align: center;
  background: radial-gradient(circle at 36% 28%, rgba(255,255,255,0.24), rgba(255,255,255,0.06) 22%, rgba(213,182,132,0.18) 52%, rgba(43,30,24,0.42) 72%, rgba(10,8,7,0.58) 100%);
  border: 1rpx solid rgba(238,215,178,0.22);
  color: #f5e0ba;
  font-size: 46rpx;
  font-weight: 700;
}

.state {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 160rpx 32rpx;
  color: rgba(243,234,223,0.52);
  font-size: 30rpx;
}

.empty-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  border-radius: 34rpx;
  padding: 56rpx 36rpx;
  text-align: center;
  background: linear-gradient(135deg, rgba(57,44,36,0.94), rgba(28,22,19,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 22rpx 56rpx rgba(0,0,0,0.40), inset 0 1rpx 0 rgba(255,255,255,0.12);
}
.empty-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 6rpx; font-weight: 700; margin-bottom: 18rpx; }
.empty-title { display: block; font-size: 38rpx; color: #fff1dc; font-weight: 700; }
.empty-desc { display: block; margin-top: 18rpx; font-size: 26rpx; color: rgba(243,234,223,0.66); line-height: 1.64; }

.list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.shop-item {
  position: relative;
  overflow: hidden;
  border-radius: 32rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(82,62,50,0.96), rgba(36,28,24,0.98));
  border: 1rpx solid rgba(227,196,160,0.18);
  box-shadow: 0 22rpx 54rpx rgba(0,0,0,0.34), inset 0 1rpx 0 rgba(255,255,255,0.10);
}
.shop-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255,255,255,0.10), transparent 28%, transparent 72%, rgba(217,138,131,0.04));
}
.item-top,
.item-grid,
.buy-btn { position: relative; z-index: 1; }
.item-top { display: flex; align-items: flex-start; gap: 18rpx; }
.item-badge {
  width: 90rpx;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 28rpx;
  text-align: center;
  background: linear-gradient(135deg, #ead2a1, #cfa668);
  color: #35261c;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(207,166,104,0.18);
  flex: 0 0 auto;
}
.item-copy { flex: 1; min-width: 0; }
.item-kicker { display: block; font-size: 18rpx; color: #dec18e; letter-spacing: 5rpx; font-weight: 700; margin-bottom: 12rpx; }
.item-name { display: block; font-size: 36rpx; line-height: 1.18; color: #fff2dc; font-weight: 700; }
.item-rule { display: block; margin-top: 10rpx; font-size: 24rpx; color: rgba(243,234,223,0.64); line-height: 1.6; }

.item-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}
.info-cell {
  width: calc(50% - 7rpx);
  min-height: 112rpx;
  border-radius: 22rpx;
  padding: 22rpx;
  box-sizing: border-box;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(227,196,160,0.10);
}
.info-cell--full { width: 100%; min-height: 96rpx; }
.info-label { display: block; font-size: 22rpx; color: rgba(243,234,223,0.48); margin-bottom: 12rpx; }
.info-value { display: block; font-size: 26rpx; color: #f7ecdd; line-height: 1.5; }
.info-price { font-size: 40rpx; color: #f4d0b0; font-weight: 700; }
.muted { color: rgba(243,234,223,0.42); }

.buy-btn {
  margin-top: 24rpx;
  width: 100%;
  height: 92rpx !important;
  line-height: 92rpx !important;
  border-radius: 999rpx !important;
  border: none !important;
  background: linear-gradient(135deg, #d98a83, #e6ac9f) !important;
  color: #fff7ef !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  letter-spacing: 1rpx !important;
  box-shadow: 0 14rpx 32rpx rgba(217,138,131,0.26) !important;
}
.buy-btn::after { border: none; }
.buy-btn--disabled {
  background: rgba(255,255,255,0.06) !important;
  color: rgba(243,234,223,0.42) !important;
  box-shadow: none !important;
}
