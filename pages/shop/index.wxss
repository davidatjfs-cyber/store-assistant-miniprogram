page { background: #fbf4e8; color: #261c16; }

.page {
  min-height: 100vh;
  padding: 42rpx 32rpx 56rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 5%, rgba(141,35,45,0.10), transparent 30%),
    radial-gradient(circle at 86% 16%, rgba(101,122,76,0.12), transparent 34%),
    linear-gradient(180deg, #fff8ed, #f7ecdc 62%);
}

.top-bar { padding: 36rpx 4rpx 28rpx; }
.top-title { display: block; font-size: 54rpx; line-height: 1.05; font-weight: 900; color: #261c16; letter-spacing: 0; }
.top-title::before { content: 'DINING DEALS'; display: block; margin-bottom: 14rpx; font-size: 20rpx; line-height: 1; color: #8d232d; letter-spacing: 4rpx; font-weight: 900; }

.state { text-align: center; padding: 140rpx 32rpx; color: rgba(38,28,22,0.60); font-size: 28rpx; }
.empty { text-align: center; padding: 150rpx 44rpx; }
.empty-title { display: block; font-size: 34rpx; color: #261c16; margin-bottom: 14rpx; font-weight: 900; }
.empty-desc { display: block; font-size: 26rpx; color: rgba(38,28,22,0.52); }

.list { display: flex; flex-direction: column; gap: 22rpx; }

.glass-card {
  padding: 30rpx;
  border-radius: 34rpx;
  background: #fffaf2;
  border: 1rpx solid rgba(38,28,22,0.10);
  box-shadow: 0 18rpx 48rpx rgba(70,45,28,0.10);
}

.item-header { display: flex; align-items: flex-start; gap: 22rpx; margin-bottom: 22rpx; }
.item-badge {
  width: 104rpx; height: 104rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 28rpx; font-size: 31rpx; font-weight: 900; color: #fffaf2; flex-shrink: 0;
}
.badge-cash { background: #8d232d; }
.badge-discount { background: #657a4c; }
.item-info { flex: 1; padding-top: 4rpx; }
.item-name { display: block; font-size: 32rpx; line-height: 1.28; font-weight: 900; color: #261c16; }
.item-rule { display: block; font-size: 24rpx; color: rgba(38,28,22,0.54); margin-top: 10rpx; line-height: 1.45; }

.item-details { border-top: 1rpx solid rgba(38,28,22,0.08); padding-top: 18rpx; margin-bottom: 22rpx; }
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; gap: 18rpx; }
.detail-label { font-size: 24rpx; color: rgba(38,28,22,0.50); }
.detail-price { font-size: 36rpx; line-height: 1; font-weight: 900; color: #8d232d; }
.detail-value { font-size: 24rpx; color: rgba(38,28,22,0.68); text-align: right; }
.out-of-stock { color: rgba(141,35,45,0.72); }

.buy-btn {
  width: 100%; height: 92rpx !important; line-height: 92rpx !important;
  background: #8d232d !important; color: #fffaf2 !important;
  border: none !important; border-radius: 999rpx !important;
  font-size: 28rpx !important; font-weight: 900 !important; letter-spacing: 0 !important;
  box-shadow: 0 14rpx 34rpx rgba(141,35,45,0.18) !important;
}
.buy-btn::after { border: none; }
.buy-btn--disabled { background: rgba(38,28,22,0.10) !important; color: rgba(38,28,22,0.36) !important; box-shadow: none !important; }
