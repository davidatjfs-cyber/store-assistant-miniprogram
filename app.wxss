page {
  height: 100%;
  background: #0d0d0d;
  color: #e8e0d4;
  font-family: 'Avenir Next', 'SF Pro Text', 'PingFang SC', 'Hiragino Sans GB', 'Helvetica Neue', sans-serif;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: linear-gradient(175deg, #0d0d0d 0%, #1a1412 35%, #0d0d0d 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.liquid-panel {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(201,169,110,0.06) 35%, rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24rpx) saturate(140%);
  -webkit-backdrop-filter: blur(24rpx) saturate(140%);
  border: 1rpx solid rgba(255,255,255,0.12);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.38), inset 0 1rpx 0 rgba(255,255,255,0.12);
}

.liquid-panel::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255,255,255,0.12), transparent 34%, transparent 68%, rgba(201,169,110,0.06));
  pointer-events: none;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #d4b87a;
  letter-spacing: 1rpx;
  font-family: 'Avenir Next', 'SF Pro Display', 'PingFang SC', sans-serif;
}

.subtitle {
  font-size: 28rpx;
  color: #a89b8c;
}

.desc {
  font-size: 26rpx;
  color: #8a7e72;
  line-height: 1.6;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
  letter-spacing: 0.5rpx;
  font-family: 'Avenir Next', 'SF Pro Text', 'PingFang SC', sans-serif;
}
button::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #c9a96e 0%, #d4b87a 50%, #c9a96e 100%);
  color: #0d0d0d;
  box-shadow: 0 8rpx 28rpx rgba(201, 169, 110, 0.25);
}

.btn-outline {
  background: transparent;
  color: #d4b87a;
  border: 1rpx solid rgba(212, 184, 122, 0.35);
}

.btn-scan {
  background: linear-gradient(135deg, #c9a96e 0%, #d4b87a 100%);
  color: #0d0d0d;
  box-shadow: 0 8rpx 28rpx rgba(201, 169, 110, 0.25);
}

.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.badge--unused {
  background: linear-gradient(135deg, #c9a96e, #d4b87a);
  color: #0d0d0d;
}

.badge--used {
  background: rgba(232, 224, 212, 0.08);
  color: #8a7e72;
  border: 1rpx solid rgba(232, 224, 212, 0.1);
}

.badge--expired {
  background: rgba(232, 224, 212, 0.08);
  color: #8a7e72;
  border: 1rpx solid rgba(232, 224, 212, 0.1);
}

.field-input {
  background: rgba(232, 224, 212, 0.06);
  border: 1rpx solid rgba(212, 184, 122, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #e8e0d4;
}

.field-input::placeholder {
  color: rgba(232, 224, 212, 0.3);
}

.state {
  text-align: center;
  padding: 120rpx 32rpx;
  color: #8a7e72;
  font-size: 28rpx;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(212, 184, 122, 0.15) 50%, transparent 100%);
  margin: 32rpx 0;
}

.empty {
  text-align: center;
  padding: 160rpx 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8a7e72;
}
