/**
 * 门店私域助手 - 液态玻璃风格 (高亮银色)
 */

page {
  height: 100%;
  background: #0a0a0a;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #0a0a0a 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

/* 高亮银色文字 */
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 12rpx rgba(255,255,255,0.6);
  letter-spacing: -0.5rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #E8E8E8;
  text-shadow: 0 0 8rpx rgba(255,255,255,0.3);
}

.desc {
  font-size: 26rpx;
  color: #C0C0C0;
  line-height: 1.6;
}

/* 按钮 */
button {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 1rpx;
}

button::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6a00 0%, #ff8533 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255,106,0,0.4);
}

.btn-outline {
  background: rgba(255,255,255,0.1);
  color: #ffffff;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.btn-scan {
  background: linear-gradient(135deg, #ff6a00 0%, #ff8533 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255,106,0,0.4);
}

/* 徽章 */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge--unused {
  background: linear-gradient(135deg, #ff6a00 0%, #ff8533 100%);
  color: #ffffff;
}

.badge--used {
  background: rgba(255,255,255,0.15);
  color: #E8E8E8;
}

.badge--expired {
  background: rgba(255,255,255,0.15);
  color: #E8E8E8;
}

/* 输入框 */
.field-input {
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.field-input::placeholder {
  color: rgba(255,255,255,0.4);
}

/* 状态 */
.state {
  text-align: center;
  padding: 120rpx 32rpx;
  color: #C0C0C0;
  font-size: 28rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
  margin: 32rpx 0;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 160rpx 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #C0C0C0;
}
